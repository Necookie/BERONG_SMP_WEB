---
// Hero.astro – Full-viewport hero with background image, status badge, server address copy widget
import { Image } from 'astro:assets';
import heroBg from '../../assets/images/hero-background.jpg';
import mascot from '../../assets/images/berong-mascot.png';
---

<header
  class="relative pt-32 pb-24 lg:pt-48 lg:pb-32 flex items-center justify-center min-h-[90vh] overflow-hidden"
>
  <!-- Background image layer -->
  <div class="absolute inset-0 z-0">
    <div
      class="absolute inset-0 bg-gradient-to-b from-surface-deep/80 via-surface-deep/60 to-surface-deep z-10"
    ></div>
    <Image
      src={heroBg}
      alt="Minecraft disaster simulation environment – dark voxel world with dramatic lighting"
      class="w-full h-full object-cover object-center opacity-40 mix-blend-luminosity"
      width={1920}
      height={1080}
      loading="eager"
      quality={85}
    />
  </div>

  <!-- Content -->
  <div
    class="relative z-20 max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-center flex flex-col items-center"
  >
    <!-- Status badge -->
    <div
      class="inline-flex items-center gap-2 px-3 py-1 bg-surface-elevated stone-border mb-6 font-mono text-xs font-medium tracking-widest text-experience-orb"
    >
      <span class="w-2 h-2 bg-experience-orb shadow-[0_0_8px_#7cfc00] inline-block"></span>
      Server Online — Version 1.21 NeoForge
    </div>

    <!-- H1 -->
    <h1
      class="font-headline text-5xl md:text-[64px] md:leading-[72px] font-bold text-white mb-6 tracking-tighter uppercase text-shadow-mc"
    >
      BERONG <span class="text-primary">SMP</span>
    </h1>

    <!-- Tagline -->
    <p
      class="font-body text-body-md md:text-lg text-on-surface-variant max-w-2xl mx-auto mb-10 leading-relaxed"
    >
      A rigorous, Minecraft-based disaster simulation platform engineered for academic research in
      fire and earthquake safety protocols.
    </p>

    <!-- CTA row -->
    <div class="flex flex-col sm:flex-row items-center gap-4 justify-center">
      <!-- Server address copy widget -->
      <div class="flex items-center bg-surface-elevated stone-border p-1 w-full sm:w-auto">
        <div
          id="hero-server-address"
          class="px-4 py-3 font-mono text-xs font-medium text-on-surface border-r border-border-stone select-all flex-1 text-center sm:text-left"
        >
          berongsmpdev.mcsh.io
        </div>
        <button
          id="hero-copy-btn"
          aria-label="Copy server address to clipboard"
          class="p-3 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-center"
        >
          <span class="material-symbols-outlined" style="font-size:20px;" aria-hidden="true"
            >content_copy</span
          >
        </button>
      </div>

      <!-- Join CTA -->
      <button
        class="mc-button px-8 py-4 font-mono text-xs font-medium uppercase tracking-widest w-full sm:w-auto"
        onclick="document.getElementById('enroll').scrollIntoView({behavior:'smooth'})"
      >
        Join Now
      </button>
    </div>
  </div>

  <!-- Mascot (Berong Waving) -->
  <div
    class="hidden lg:block absolute bottom-0 right-0 z-10 w-[300px] xl:w-[420px] pointer-events-none select-none opacity-85 xl:opacity-100 transition-all duration-500 translate-x-4 xl:translate-x-0 animate-mascot-float"
  >
    <img
      src={mascot.src}
      alt="Berong Mascot - Bureau of Fire Protection waving bull"
      class="w-full h-auto object-contain object-bottom-right"
      width={420}
      height={630}
      loading="eager"
    />
  </div>
</header>

<script>
  const btn = document.getElementById('hero-copy-btn');
  const addr = document.getElementById('hero-server-address');
  if (btn && addr) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(addr.textContent?.trim() ?? '');
        const icon = btn.querySelector('span');
        if (icon) {
          icon.textContent = 'check';
          icon.classList.add('text-primary');
          setTimeout(() => {
            icon.textContent = 'content_copy';
            icon.classList.remove('text-primary');
          }, 1800);
        }
      } catch {
        /* clipboard not available in insecure context */
      }
    });
  }
</script>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  .animate-mascot-float {
    animation: float 6s ease-in-out infinite;
  }
</style>
