---
// About.astro – Two-column section with project overview and screenshot
import { Image } from 'astro:assets';
import fireSim from '../../assets/images/fire-extinguisher-sim.jpg';
---

<section
  class="py-24 bg-surface-base border-y border-border-stone relative"
  id="about"
  aria-labelledby="about-heading"
>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Text column -->
      <div class="space-y-8 reveal">
        <div class="section-label">
          <span class="material-symbols-outlined" style="font-size:16px;" aria-hidden="true"
            >info</span
          >
          Thesis Project
        </div>

        <h2 id="about-heading" class="font-headline text-2xl md:text-3xl font-semibold text-white">
          The Science of Survival in a Voxel World.
        </h2>

        <div class="space-y-4 text-on-surface-variant font-body text-body-md">
          <p>
            BERONG SMP evolved from an academic "Fire Extinguisher Prototype" into a comprehensive
            disaster simulation environment. Operating on Minecraft 1.21 via the NeoForge modding
            API, this platform provides a controlled setting to study human behavior and emergency
            response during simulated crises.
          </p>
          <p>
            The environment rigorously tests participants' ability to navigate hazards, utilize
            safety equipment, and follow established protocols in high-stress, procedurally generated
            or meticulously reconstructed scenarios.
          </p>
        </div>

        <!-- Stats -->
        <dl class="flex items-end gap-10 pt-4">
          <div>
            <dd class="font-headline text-3xl font-semibold text-white m-0">1.21</dd>
            <dt class="font-mono text-xs font-medium text-primary tracking-widest uppercase mt-1">NeoForge</dt>
          </div>
          <div class="w-px h-8 bg-surface-container-high self-center" aria-hidden="true"></div>
          <div>
            <dd class="font-headline text-3xl font-semibold text-white m-0">2+</dd>
            <dt class="font-mono text-xs font-medium text-primary tracking-widest uppercase mt-1">Sim Types</dt>
          </div>
        </dl>
      </div>

      <!-- Image column with hover glow -->
      <div class="relative group">
        <div
          class="absolute -inset-2 bg-primary/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          aria-hidden="true"
        ></div>
        <div class="relative aspect-video stone-border overflow-hidden bg-surface-container p-2">
          <Image
            src={fireSim}
            alt="Fire extinguisher prototype simulation inside the Minecraft environment — players navigating a burning room"
            class="w-full h-full object-cover"
            width={800}
            height={450}
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
