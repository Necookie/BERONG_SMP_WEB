---
// Features.astro – Core Systems section
// Layout: 2 primary scenario cards (large) + 4 supporting systems (compact grouped list)
// Broke the identical 6-card grid per /impeccable quieter — primary scenarios get
// prominence, supporting systems get a unified container.
---

<section
  class="py-24 relative"
  id="features"
  aria-labelledby="features-heading"
>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <h2
        id="features-heading"
        class="font-headline text-2xl md:text-3xl font-semibold text-white mb-4"
      >
        Core Systems
      </h2>
      <p class="font-body text-body-md text-on-surface-variant max-w-2xl mx-auto">
        Engineered modifications designed for realistic emergency scenarios.
      </p>
    </div>

    <!-- Primary scenarios — large cards with full description -->
    <div class="grid md:grid-cols-2 gap-6 mb-6 reveal-stagger">

      <!-- Fire Simulation -->
      <article
        class="bg-surface-elevated p-8 stone-border hover:border-primary/50 hover:-translate-y-0.5 transition-all duration-200"
        aria-label="Fire Simulation"
      >
        <div class="w-12 h-12 bg-surface-container stone-border flex items-center justify-center mb-6">
          <span class="material-symbols-outlined text-primary" style="font-variation-settings:'FILL' 1; font-size:24px;" aria-hidden="true">local_fire_department</span>
        </div>
        <h3 class="font-headline text-sm font-bold text-white mb-3 uppercase tracking-wide">Fire Simulation</h3>
        <p class="font-body text-body-sm text-on-surface-variant leading-relaxed">Advanced fire propagation physics and interactive extinguisher mechanics requiring proper P.A.S.S. technique under timed conditions.</p>
      </article>

      <!-- Earthquake Engine -->
      <article
        class="bg-surface-elevated p-8 stone-border hover:border-primary/50 hover:-translate-y-0.5 transition-all duration-200"
        aria-label="Earthquake Engine"
      >
        <div class="w-12 h-12 bg-surface-container stone-border flex items-center justify-center mb-6">
          <span class="material-symbols-outlined text-primary" style="font-variation-settings:'FILL' 1; font-size:24px;" aria-hidden="true">crisis_alert</span>
        </div>
        <h3 class="font-headline text-sm font-bold text-white mb-3 uppercase tracking-wide">Earthquake Engine</h3>
        <p class="font-body text-body-sm text-on-surface-variant leading-relaxed">Procedural structural degradation, falling debris hazards, and simulated seismic tremors affecting player movement and visibility.</p>
      </article>

    </div>

    <!-- Supporting systems — compact grouped container, not individual cards -->
    <div class="bg-surface-container/40 stone-border reveal">
      <div class="grid grid-cols-1 sm:grid-cols-2 divide-y divide-border-stone sm:divide-y-0 sm:grid-rows-2">

        <!-- Row 1 -->
        <div class="p-6 flex gap-4 items-start sm:border-r sm:border-border-stone sm:border-b sm:border-border-stone">
          <span class="material-symbols-outlined text-primary shrink-0 mt-0.5" style="font-size:20px; font-variation-settings:'FILL' 1;" aria-hidden="true">meeting_room</span>
          <div>
            <h3 class="font-mono text-xs font-bold text-white uppercase tracking-wider mb-1">Lobby System</h3>
            <p class="font-body text-body-sm text-on-surface-variant">Secure staging area for briefing, equipment loadout, and scenario selection.</p>
          </div>
        </div>

        <div class="p-6 flex gap-4 items-start sm:border-b sm:border-border-stone">
          <span class="material-symbols-outlined text-primary shrink-0 mt-0.5" style="font-size:20px; font-variation-settings:'FILL' 1;" aria-hidden="true">timer</span>
          <div>
            <h3 class="font-mono text-xs font-bold text-white uppercase tracking-wider mb-1">Real-Time HUD</h3>
            <p class="font-body text-body-sm text-on-surface-variant">Mission timers, objective checklists, and live environmental hazard warnings.</p>
          </div>
        </div>

        <!-- Row 2 -->
        <div class="p-6 flex gap-4 items-start sm:border-r sm:border-border-stone">
          <span class="material-symbols-outlined text-primary shrink-0 mt-0.5" style="font-size:20px; font-variation-settings:'FILL' 1;" aria-hidden="true">location_city</span>
          <div>
            <h3 class="font-mono text-xs font-bold text-white uppercase tracking-wider mb-1">Custom Structures</h3>
            <p class="font-body text-body-sm text-on-surface-variant">1:1 scale reconstructions of real-world academic facilities, including the LSPU Library.</p>
          </div>
        </div>

        <div class="p-6 flex gap-4 items-start">
          <span class="material-symbols-outlined text-primary shrink-0 mt-0.5" style="font-size:20px; font-variation-settings:'FILL' 1;" aria-hidden="true">school</span>
          <div>
            <h3 class="font-mono text-xs font-bold text-white uppercase tracking-wider mb-1">Educational Focus</h3>
            <p class="font-body text-body-sm text-on-surface-variant">Evaluation systems mapping player actions to established institutional safety protocols.</p>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>
