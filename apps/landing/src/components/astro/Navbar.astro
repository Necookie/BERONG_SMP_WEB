---
// Navbar.astro – Fixed top nav; imports MobileMenu React island for the hamburger toggle
import { Image } from 'astro:assets';
import MobileMenu from '../react/MobileMenu';
import ThemeToggle from './ThemeToggle.astro';
import logo from '../../assets/images/berong-elearning-logo.png';

const isCommandsPage = Astro.url.pathname.startsWith('/commands');

const navLinks = [
  { href: isCommandsPage ? '/' : '#',        label: 'Home'     },
  { href: isCommandsPage ? '/#about' : '#about',   label: 'About'    },
  { href: isCommandsPage ? '/#features' : '#features',label: 'Features' },
  { href: isCommandsPage ? '/#gallery' : '#gallery', label: 'Gallery'  },
  { href: isCommandsPage ? '/#rules' : '#rules',   label: 'Rules'    },
  { href: isCommandsPage ? '/#instructions' : '#instructions', label: 'Instructions' },
  { href: '/commands', label: 'Commands' },
];
---

<nav
  class="bg-surface-deep fixed top-0 w-full z-50 glass-panel"
  aria-label="Primary navigation"
>
  <div class="flex justify-between items-center px-margin-mobile md:px-margin-desktop py-4 max-w-container-max mx-auto">
    <!-- Logo -->
    <a href="/" aria-label="BERONG SMP home" class="flex items-center gap-3">
      <Image
        src={logo}
        alt="BERONG SMP logo"
        class="h-10 w-10 md:h-12 md:w-12 object-contain"
        width={48}
        height={48}
        loading="eager"
        format="webp"
        quality={85}
      />
      <span class="font-headline text-lg md:text-xl font-bold text-white uppercase tracking-wider">
        Berong <span class="text-primary">SMP</span>
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8 list-none" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={[
              'font-mono text-xs font-medium tracking-widest uppercase transition-colors',
              (isCommandsPage ? label === 'Commands' : label === 'Home')
                ? 'text-primary border-b-2 border-primary pb-1'
                : 'text-on-surface-variant hover:text-on-surface hover:bg-surface-bright/10 px-2 py-1',
            ].join(' ')}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <div class="flex items-center gap-2">
      <a
        href="#enroll"
        class="mc-button px-6 py-2 font-mono text-xs font-medium uppercase tracking-wider hidden md:block"
      >
        Join Server
      </a>

      <!-- Theme toggle -->
      <ThemeToggle />

      <!-- Mobile menu island — only loads JS when scrolled into view -->
      <MobileMenu links={navLinks} client:visible />
    </div>
  </div>
</nav>
