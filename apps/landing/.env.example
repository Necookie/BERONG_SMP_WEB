# Public environment variable for the FastAPI backend base URL.
# This variable is exposed to the browser (Astro PUBLIC_ prefix).
# Do NOT put secrets or private API keys in PUBLIC_ variables.
#
# Development (local FastAPI server):
PUBLIC_API_BASE_URL=http://localhost:8000
#
# Production example:
# PUBLIC_API_BASE_URL=https://api.berongsmp.dev
#
# Once the backend /leads endpoint path is confirmed, update src/lib/api.ts accordingly.
# Current assumed path: POST /leads
