---
import '../styles/global.css';

import { Image } from 'astro:assets';
import logo from '../assets/images/berong-elearning-logo.png';
import ThemeToggle from '../components/ThemeToggle';

interface Props {
  title: string;
  currentPath: string;
  fullscreen?: boolean;
}

const { title, currentPath, fullscreen = false } = Astro.props;

const navItems = [
  { href: '/',         label: 'Overview',  badge: 'SUMMARY'  },
  { href: '/sessions', label: 'Sessions',  badge: 'LOG'      },
  { href: '/roster',   label: 'Roster',    badge: 'ROSTER'   },
  { href: '/data',     label: 'Data',      badge: 'EXPORT'   },
  { href: '/commands', label: 'Commands',  badge: 'REFERENCE'},
  { href: '/guide',    label: 'Guide',     badge: 'DOCS'     },
];
---

<!doctype html>
<html lang="en">
<head>
  <!-- Inline theme script: runs before paint to prevent flash of wrong theme -->
  <script is:inline>
    (function () {
      const stored = localStorage.getItem('theme');
      const prefersDark =
        stored === 'dark' ||
        (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
      document.documentElement.classList.add(prefersDark ? 'dark' : 'light');
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — BERONG SMP</title>
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Material Symbols Outlined -->
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
    rel="stylesheet"
  />
</head>
<body>

  <!-- Mobile top bar (hamburger) — hidden on desktop via CSS -->
  <div class="mobile-topbar" id="mobile-topbar">
    <button class="hamburger-btn" id="hamburger-btn" aria-label="Open navigation menu" aria-expanded="false">
      <span class="hamburger-icon">☰</span>
    </button>
    <span class="mobile-topbar-title">BERONG SMP</span>
    <ThemeToggle client:only="react" />
  </div>

  <!-- Sidebar overlay backdrop -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <div class="dashboard-shell">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-brand flex items-center gap-3">
        <Image
          src={logo}
          alt="BERONG SMP logo"
          class="w-9 h-9 object-contain"
          width={36}
          height={36}
          format="webp"
          quality={85}
        />
        <div>
          <span class="sidebar-brand-name">BERONG SMP</span>
          <span class="sidebar-brand-sub">Drill Review · BFP / LSPU</span>
        </div>
      </div>

      <nav class="sidebar-nav">
        <span class="nav-group-label">Navigation</span>
        {navItems.map(item => (
          <a
            href={item.href}
            class={`nav-item${currentPath === item.href ? ' active' : ''}`}
          >
            <span class="nav-label">{item.label}</span>
            <span class="nav-badge">{item.badge}</span>
          </a>
        ))}
      </nav>

      <div class="sidebar-footer flex items-center justify-between">
        <div class="status-line">
          <span class="status-dot"></span>
          MOCK DATA · v0.1
        </div>
        <ThemeToggle client:only="react" />
      </div>
    </aside>

    <!-- Main -->
    <main class={`main-area${fullscreen ? ' fullscreen' : ''}`}>
      <slot />
    </main>

  </div>
</body>
</html>

<script is:inline>
  (function () {
    const hamburger = document.getElementById('hamburger-btn');
    const sidebar   = document.getElementById('sidebar');
    const overlay   = document.getElementById('sidebar-overlay');

    function openSidebar() {
      sidebar.classList.add('open');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      hamburger.setAttribute('aria-expanded', 'true');
    }

    function closeSidebar() {
      sidebar.classList.remove('open');
      overlay.classList.remove('active');
      document.body.style.overflow = '';
      hamburger.setAttribute('aria-expanded', 'false');
    }

    if (hamburger && sidebar && overlay) {
      hamburger.addEventListener('click', function () {
        if (sidebar.classList.contains('open')) {
          closeSidebar();
        } else {
          openSidebar();
        }
      });

      overlay.addEventListener('click', closeSidebar);

      // Close on nav item click on mobile
      sidebar.querySelectorAll('.nav-item').forEach(function (link) {
        link.addEventListener('click', function () {
          if (window.innerWidth <= 768) closeSidebar();
        });
      });
    }
  })();
</script>

