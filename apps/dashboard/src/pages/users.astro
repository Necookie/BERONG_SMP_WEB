---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getEnv } from '../lib/db';
import { getAllUsers } from '../lib/queries';

const user = Astro.locals.user;
if (!user || user.role !== 'owner') {
  return Astro.redirect('/');
}

const env = await getEnv();
if (!env) {
  return Astro.redirect('/error');
}

let users: Awaited<ReturnType<typeof getAllUsers>> = [];
try {
  users = await getAllUsers(env);
} catch (err) {
  console.error('Error loading users:', err);
}

const total     = users.length;
const active    = users.filter(u => u.status === 'active').length;
const pending   = users.filter(u => u.status === 'pending').length;
const suspended = users.filter(u => u.status === 'suspended').length;
---

<DashboardLayout title="User Management" currentPath="/users">

  <div class="page-header page-header--split">
    <div>
      <h1 class="page-title">User Management</h1>
      <p class="page-meta">
        {total} administrator{total !== 1 ? 's' : ''} · {pending} pending approval · manage access and suspensions
      </p>
    </div>
    <span class="owner-badge">
      <span class="material-symbols-outlined" style="font-size: 13px; line-height: 1;">shield_person</span>
      Owner Mode
    </span>
  </div>

  <!-- Alert Message Box -->
  <div id="action-alert" class="users-alert hidden"></div>

  <div class="kpi-strip">
    <div class="kpi-item">
      <span class="kpi-label">Total accounts</span>
      <span class="kpi-value">{total}</span>
    </div>
    <div class="kpi-item">
      <span class="kpi-label">Active</span>
      <span class="kpi-value" style="color: var(--text-success);">{active}</span>
    </div>
    <div class="kpi-item">
      <span class="kpi-label">Pending approval</span>
      <span class="kpi-value" style="color: var(--text-warning);">{pending}</span>
    </div>
    <div class="kpi-item">
      <span class="kpi-label">Suspended</span>
      <span class="kpi-value" style="color: var(--text-danger);">{suspended}</span>
    </div>
  </div>

  <div class="sessions-section">
    <div class="dist-head">
      <span class="section-label">Administrator accounts</span>
      <span class="dist-cohort">{total} total</span>
    </div>

    {users.length === 0 ? (
      <div class="sessions-empty">
        <span class="material-symbols-outlined" style="font-size: 32px; color: var(--text-muted); opacity: 0.4;">group_off</span>
        <p class="sessions-empty-text" style="margin-top: 8px;">No administrator account requests found.</p>
      </div>
    ) : (
      <div class="table-scroll-wrap">
        <table class="sessions-table users-table">
          <thead>
            <tr>
              <th>Username</th>
              <th>Role</th>
              <th>Status</th>
              <th>Created at</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {users.map(u => (
              <tr data-user-id={u.id}>
                <td class="name-cell">
                  <span class="material-symbols-outlined" style="font-size: 14px; vertical-align: -2px; opacity: 0.5; margin-right: 4px;">person</span>
                  {u.username}
                </td>
                <td>
                  <span class={`role-chip ${u.role === 'owner' ? 'owner' : ''}`}>{u.role}</span>
                </td>
                <td>
                  {u.status === 'active' && (
                    <span class="status-pill active"><span class="dot"></span>Active</span>
                  )}
                  {u.status === 'pending' && (
                    <span class="status-pill pending"><span class="dot"></span>Pending</span>
                  )}
                  {u.status === 'suspended' && (
                    <span class="status-pill suspended"><span class="dot"></span>Suspended</span>
                  )}
                </td>
                <td class="td-mono-id">{new Date(u.created_at).toLocaleString()}</td>
                <td class="actions-cell">
                  <div class="user-actions">
                    {u.status !== 'active' ? (
                      <button
                        class="user-action-btn approve"
                        data-id={u.id}
                        data-action="approve"
                      >
                        <span class="material-symbols-outlined" style="font-size: 13px;">check_circle</span>
                        Approve
                      </button>
                    ) : (
                      <button
                        class="user-action-btn suspend"
                        data-id={u.id}
                        data-action="suspend"
                      >
                        <span class="material-symbols-outlined" style="font-size: 13px;">block</span>
                        Suspend
                      </button>
                    )}
                    <button
                      class="user-action-btn delete"
                      data-id={u.id}
                      data-action="delete"
                    >
                      <span class="material-symbols-outlined" style="font-size: 13px;">delete</span>
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

</DashboardLayout>

<script>
  const alertBox = document.getElementById('action-alert');
  const buttons = document.querySelectorAll('.user-action-btn');

  function showAlert(msg: string, type: 'success' | 'error') {
    if (!alertBox) return;
    alertBox.textContent = msg;
    alertBox.className = `users-alert ${type}`;
    setTimeout(() => {
      alertBox.classList.add('hidden');
    }, 4000);
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const action = btn.getAttribute('data-action');
      if (!id || !action) return;

      if (action === 'delete') {
        const confirmDelete = confirm('Are you sure you want to permanently delete this administrator account?');
        if (!confirmDelete) return;
      }

      try {
        btn.setAttribute('disabled', 'true');
        const res = await fetch(`/api/auth/users/${id}/${action}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });

        const data = await res.json() as any;
        if (res.ok && data.ok) {
          showAlert(`User successfully ${action}d!`, 'success');

          // Reload page after a delay to show updated status
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          showAlert(data.error || 'Action failed', 'error');
          btn.removeAttribute('disabled');
        }
      } catch (err) {
        showAlert('A network connection error occurred', 'error');
        btn.removeAttribute('disabled');
      }
    });
  });
</script>
