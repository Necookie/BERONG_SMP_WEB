---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getEnv } from '../lib/db';
import { getAllUsers } from '../lib/queries';

const user = Astro.locals.user;
if (!user || user.role !== 'owner') {
  return Astro.redirect('/');
}

const env = await getEnv();
if (!env) {
  return Astro.redirect('/error');
}

let users = [];
try {
  users = await getAllUsers(env);
} catch (err) {
  console.error('Error loading users:', err);
}
---

<DashboardLayout title="User Management" currentPath="/users">
  <div class="page-container">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="page-title text-heading font-display">User Management</h1>
        <p class="text-secondary text-sm mt-1">Manage administrator access, approve requests, and suspend accounts.</p>
      </div>
      <span class="role-badge px-3 py-1 rounded-full text-xs font-semibold" style="background: rgba(136, 217, 130, 0.08); color: var(--text-brand); border: 1px solid rgba(136, 217, 130, 0.15);">
        Owner Mode
      </span>
    </div>

    <!-- Alert Message Box -->
    <div id="action-alert" class="hidden p-4 rounded-lg mb-6 border text-sm backdrop-blur-sm transition-all duration-300"></div>

    <div class="card p-6 md:p-8 border border-card bg-card rounded-2xl shadow-xl overflow-hidden">
      {users.length === 0 ? (
        <div class="py-12 text-center text-secondary">
          <span class="material-symbols-outlined text-4xl opacity-40 mb-2">group_off</span>
          <p>No administrator accounts requests found.</p>
        </div>
      ) : (
        <div class="table-scroll-wrapper">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b border-table" style="border-color: var(--border-table);">
                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-secondary">Username</th>
                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-secondary">Role</th>
                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-secondary">Status</th>
                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-secondary">Created At</th>
                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-secondary text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              {users.map(u => (
                <tr class="border-b border-table hover:bg-table-hover transition-colors" style="border-color: var(--border-table);" data-user-id={u.id}>
                  <td class="py-4 px-4 font-mono text-sm text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm opacity-60">person</span>
                    {u.username}
                  </td>
                  <td class="py-4 px-4 text-sm text-secondary">
                    <span class="text-xs uppercase px-2 py-0.5 rounded font-mono" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); color: var(--text-secondary);">
                      {u.role}
                    </span>
                  </td>
                  <td class="py-4 px-4 text-sm">
                    {u.status === 'active' && (
                      <span class="status-badge px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-950/20 text-emerald-400 border border-emerald-900/30 dark:bg-emerald-950/20 dark:text-emerald-400">
                        Active
                      </span>
                    )}
                    {u.status === 'pending' && (
                      <span class="status-badge px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-950/20 text-amber-400 border border-amber-900/30 dark:bg-amber-950/20 dark:text-amber-400">
                        Pending Approval
                      </span>
                    )}
                    {u.status === 'suspended' && (
                      <span class="status-badge px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-950/20 text-red-400 border border-red-900/30 dark:bg-red-950/20 dark:text-red-400">
                        Suspended
                      </span>
                    )}
                  </td>
                  <td class="py-4 px-4 text-xs font-mono text-muted">
                    {new Date(u.created_at).toLocaleString()}
                  </td>
                  <td class="py-4 px-4 text-right">
                    <div class="flex items-center justify-end gap-2">
                      {u.status !== 'active' ? (
                        <button
                          class="action-btn approve-btn px-3 py-1.5 rounded-lg text-xs font-semibold flex items-center gap-1 transition-all"
                          data-id={u.id}
                          data-action="approve"
                          style="background: rgba(136, 217, 130, 0.08); color: var(--text-brand); border: 1px solid rgba(136, 217, 130, 0.15);"
                        >
                          <span class="material-symbols-outlined" style="font-size: 14px;">check_circle</span>
                          Approve
                        </button>
                      ) : (
                        <button
                          class="action-btn suspend-btn px-3 py-1.5 rounded-lg text-xs font-semibold flex items-center gap-1 transition-all"
                          data-id={u.id}
                          data-action="suspend"
                          style="background: rgba(201, 168, 76, 0.08); color: #c9a84c; border: 1px solid rgba(201, 168, 76, 0.15);"
                        >
                          <span class="material-symbols-outlined" style="font-size: 14px;">block</span>
                          Suspend
                        </button>
                      )}
                      
                      <button
                        class="action-btn delete-btn px-3 py-1.5 rounded-lg text-xs font-semibold flex items-center gap-1 transition-all"
                        data-id={u.id}
                        data-action="delete"
                        style="background: rgba(196, 92, 92, 0.08); color: #c45c5c; border: 1px solid rgba(196, 92, 92, 0.15);"
                      >
                        <span class="material-symbols-outlined" style="font-size: 14px;">delete</span>
                        Delete
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>

  <style>
    .page-title {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: -0.025em;
    }
    .card {
      background-color: var(--bg-card);
      border-color: var(--border-card);
    }
    .table-scroll-wrapper {
      overflow-x: auto;
      width: 100%;
    }
    th {
      color: var(--text-secondary);
    }
    td {
      color: var(--text-primary);
    }
    .action-btn:hover {
      filter: brightness(1.15);
      transform: translateY(-1px);
    }
    .action-btn:active {
      transform: translateY(0);
    }
    
    /* Light mode badge overrides */
    :global(html.light) .status-badge {
      background: rgba(0, 0, 0, 0.03) !important;
      border-color: rgba(0, 0, 0, 0.08) !important;
    }
    :global(html.light) .bg-emerald-950\/20 {
      color: #2e7d32 !important;
    }
    :global(html.light) .bg-amber-950\/20 {
      color: #b58900 !important;
    }
    :global(html.light) .bg-red-950\/20 {
      color: #c45c5c !important;
    }
  </style>

  <script>
    const alertBox = document.getElementById('action-alert');
    const buttons = document.querySelectorAll('.action-btn');

    function showAlert(msg: string, type: 'success' | 'error') {
      if (!alertBox) return;
      alertBox.textContent = msg;
      alertBox.className = ''; // reset classes
      
      if (type === 'success') {
        alertBox.classList.add(
          'p-4', 'rounded-lg', 'mb-6', 'border', 'text-sm', 'backdrop-blur-sm',
          'bg-emerald-950/20', 'text-emerald-400', 'border-emerald-900/30'
        );
      } else {
        alertBox.classList.add(
          'p-4', 'rounded-lg', 'mb-6', 'border', 'text-sm', 'backdrop-blur-sm',
          'bg-red-950/20', 'text-red-400', 'border-red-900/30'
        );
      }
      alertBox.classList.remove('hidden');
      setTimeout(() => {
        alertBox.classList.add('hidden');
      }, 4000);
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id');
        const action = btn.getAttribute('data-action');
        if (!id || !action) return;

        if (action === 'delete') {
          const confirmDelete = confirm('Are you sure you want to permanently delete this administrator account?');
          if (!confirmDelete) return;
        }

        try {
          btn.setAttribute('disabled', 'true');
          const res = await fetch(`/api/auth/users/${id}/${action}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
          });

          const data = await res.json() as any;
          if (res.ok && data.ok) {
            showAlert(`User successfully ${action}d!`, 'success');
            
            // Reload page after a delay to show updated status
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            showAlert(data.error || 'Action failed', 'error');
            btn.removeAttribute('disabled');
          }
        } catch (err) {
          showAlert('A network connection error occurred', 'error');
          btn.removeAttribute('disabled');
        }
      });
    });
  </script>
</DashboardLayout>
