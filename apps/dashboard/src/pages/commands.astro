---
import DashboardLayout from '../layouts/DashboardLayout.astro';

// Command list data
const commands = [
  {
    name: '/sim_fire',
    category: 'simulation',
    permission: 'Op Level 2+',
    permissionLevel: 'admin',
    syntax: '/sim_fire <library|ccs>',
    arguments: [
      { name: 'target', type: 'string', range: 'library | ccs', required: 'Yes', description: '"library" starts the drill in the LSPU Library (ABC extinguisher given). "ccs" starts in the CCS Admin Building (CO2 extinguisher given).' }
    ],
    description: 'Starts a Fire simulation immediately, bypassing the lobby button. Choose the target building.',
    whenToUse: [
      'Testing the fire simulation without walking to the lobby button.',
      'Admin/instructor drops a student into a fire drill in a specific building.'
    ],
    whatHappens: [
      'All three structures placed (LSPU Library, SSC Building, CCS Admin Building).',
      'Player is teleported to a random valid room inside the chosen building.',
      'ABC extinguisher (library) or CO2 extinguisher (ccs) given in hotbar slot 0.',
      'Fire blocks begin spawning every fireSpawnInterval ticks.',
      'Timer counts down from simDurationTicks.',
      'HUD displays "SIMULATION STATUS: FIRE" (library) or "SIMULATION STATUS: CCS_FIRE".'
    ],
    notes: [
      'Fails if you already have a simulation running.',
      'Cannot be run from the server console.'
    ]
  },
  {
    name: '/sim_earthquake',
    category: 'simulation',
    permission: 'Op Level 2+',
    permissionLevel: 'admin',
    syntax: '/sim_earthquake <library|ccs> [magnitude]',
    arguments: [
      { name: 'target', type: 'string', range: 'library | ccs', required: 'Yes', description: '"library" runs the drill in the LSPU Library; "ccs" runs it in the CCS Admin Building.' },
      { name: 'magnitude', type: 'double', range: '0.1 – 10.0', required: 'No', description: 'Quake intensity. If omitted, uses quakeMagnitude from config (default 5.0).' }
    ],
    description: 'Starts an Earthquake simulation immediately. Choose the building and optional magnitude.',
    whenToUse: [
      'Testing the earthquake simulation without the lobby button.',
      'Running a controlled drill at a specific intensity.',
      'Instructors scripting a lesson with a predictable magnitude.'
    ],
    whatHappens: [
      'All structures placed (LSPU Library, SSC Building, CCS Admin Building).',
      'Epicenter fixed 3–9 blocks from the chosen building interior so destruction stays inside.',
      'Player teleported to a random valid room inside the target building.',
      'Chat: "⚠ Magnitude X.X Earthquake has begun!"',
      'Phase machine: RUMBLE → PEAK → AFTERSHOCK (×2–4 waves) → END.',
      'Aftershocks use random magnitude scales (0.2–1.1× base) before finally ending.',
      'Nausea applied per phase; camera shake driven by per-player intensity = magnitude × e^(−decayRate × distance).',
      'HUD shows "SIMULATION STATUS: EARTHQUAKE" or "CCS_EARTHQUAKE" and intensity bar.'
    ],
    notes: [
      'Lobby button starts with a random magnitude 6.0–9.5 (strong range).',
      'Fails if you already have an active simulation.'
    ]
  },
  {
    name: '/sim_stop',
    category: 'simulation',
    permission: 'Any Player',
    permissionLevel: 'player',
    syntax: '/sim_stop',
    description: 'Ends your active simulation early. Behaves identically to the timer expiring naturally.',
    whenToUse: [
      'Ending a drill early (session went wrong, player is stuck, admin intervention).',
      'Resetting the arena to a clean state before starting a new session.'
    ],
    whatHappens: [
      'Active session is removed.',
      'LSPU Library + SSC Building structures are restored to their original state.',
      'HUD is cleared.',
      'Player is teleported back to the lobby spawn.',
      'If it was a FIRE session, score is printed: fires extinguished and score out of 100.'
    ],
    notes: [
      'Safe to call even if no simulation is running (no-op).',
      'Can be called from the server console to stop any running simulation by a specific player (resolves to the calling player).',
      'If the player died during the simulation, the structure is still restored but the teleport is deferred to their next respawn.'
    ]
  },
  {
    name: '/sim_magnitude',
    category: 'earthquake',
    permission: 'Op Level 2+',
    permissionLevel: 'admin',
    syntax: '/sim_magnitude <value>',
    arguments: [
      { name: 'value', type: 'double', range: '0.1 – 10.0', required: 'Yes', description: 'New magnitude value.' }
    ],
    description: 'Changes the magnitude of your currently active earthquake session live, taking effect on the very next tick.',
    whenToUse: [
      'Instructor wants to dial up intensity mid-session to demonstrate a stronger quake.',
      'Gradually increase magnitude as a teaching progression without stopping and restarting.',
      'Dial back an accidental high-magnitude start so players aren\'t overwhelmed.'
    ],
    examples: [
      { cmd: '/sim_earthquake 3.0', desc: 'Start mild for explanation' },
      { cmd: '/sim_magnitude 6.0', desc: 'Escalate during PEAK phase for impact' },
      { cmd: '/sim_magnitude 9.0', desc: 'Push to severe for demonstration' },
      { cmd: '/sim_stop', desc: 'End simulation when done' }
    ],
    notes: [
      'Fails with "No active earthquake simulation to adjust." if you have no running earthquake session.',
      'Restricted to ops — regular players cannot use this.'
    ]
  },
  {
    name: '/bfp login',
    category: 'bfp-admin',
    permission: 'Any Player (PIN required)',
    permissionLevel: 'admin',
    syntax: '/bfp login <pin>',
    arguments: [
      { name: 'pin', type: 'string', range: 'N/A', required: 'Yes', description: 'Admin authentication PIN set in bfpAdminPin config (default "1234").' }
    ],
    description: 'Authenticates you as a BFP admin for this session using the configured PIN.',
    whatHappens: [
      'Authenticates the user as BFP admin for the current session.',
      'All /bfp sub-commands become available until logout or server restart.'
    ],
    notes: [
      'OPs always bypass the PIN check.',
      'Ensure you change the default PIN in the config before going live.'
    ]
  },
  {
    name: '/bfp logout',
    category: 'bfp-admin',
    permission: 'Any Player (Authenticated)',
    permissionLevel: 'admin',
    syntax: '/bfp logout',
    description: 'Revokes your PIN-based BFP admin access.',
    whenToUse: [
      'Step away from the station so others cannot run admin commands on your account.'
    ]
  },
  {
    name: '/bfp checkin',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp checkin <student_name> | /bfp checkin <player> <student_name>',
    arguments: [
      { name: 'student_name', type: 'string', range: 'N/A', required: 'Yes', description: 'Full name of the student checking in.' },
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player account if different from the caller.' }
    ],
    description: 'Starts a new session for a student sitting at the station.',
    whatHappens: [
      'Any existing session for that account is closed and saved.',
      'Tutorial saved data for the account UUID is wiped (fresh start).',
      'A new row is inserted into Turso with status="active".'
    ],
    examples: [
      { cmd: '/bfp checkin Juan dela Cruz', desc: 'Starts session for caller as Juan dela Cruz' },
      { cmd: '/bfp checkin station2 Maria Santos', desc: 'Starts session for player "station2" as Maria Santos' }
    ]
  },
  {
    name: '/bfp checkout',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp checkout',
    description: 'Finalises the calling player\'s current session and writes results to the database.',
    whatHappens: [
      'Writes end_time and status="completed" to Turso.',
      'Useful when a student finishes and leaves without triggering a simulation end.'
    ]
  },
  {
    name: '/bfp reset',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp reset [player]',
    arguments: [
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player to reset. Defaults to caller if omitted.' }
    ],
    description: 'Wipes tutorial state and deletes the active DB row — no record is kept.',
    whenToUse: [
      'Use when a session was started by mistake or needs to be discarded.'
    ]
  },
  {
    name: '/bfp tutorial',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp tutorial [player]',
    arguments: [
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player to reset. Defaults to caller if omitted.' }
    ],
    description: 'Resets a player\'s tutorial state and immediately teleports them to the tutorial lobby.',
    whatHappens: [
      'Wipes the tutorial save and any active session.',
      'Tutorial NPCs are re-spawned at their correct positions (fixes any duplicates).',
      'Target player is teleported to the tutorial spawn.'
    ]
  },
  {
    name: '/bfp session info',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp session info',
    description: 'Prints the current session details to chat.',
    details: [
      'Student name & station account',
      'Session start time',
      'Whether the tutorial is complete',
      'Simulation type, score, and pass/fail status'
    ]
  },
  {
    name: '/bfp sessions list',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp sessions list [page]',
    arguments: [
      { name: 'page', type: 'integer', range: '1+', required: 'No', description: 'Page number for pagination.' }
    ],
    description: 'Lists the 10 most recent sessions from Turso in chat, paginated.',
    details: [
      'Each entry shows student name, account, simulation type, score, pass status, and session status.'
    ]
  },
  {
    name: '/bfp sessions export',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp sessions export',
    description: 'Queries all sessions from Turso and writes them to run/bfp_sessions_export.csv.',
    details: [
      'Columns exported: id, student_name, station_account, account_uuid, start_time, end_time, status, tutorial_completed, tutorial_duration_s, simulation_type, simulation_score, passed, notes'
    ]
  },
  {
    name: '/bfp student',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp student <name>',
    arguments: [
      { name: 'name', type: 'string', range: 'N/A', required: 'Yes', description: 'Name of the student to search.' }
    ],
    description: 'Looks up the last 10 sessions for a given student name and prints them to chat.',
    whenToUse: [
      'Checking a student\'s history across multiple attempts.'
    ]
  },
  {
    name: '/sim_status',
    category: 'simulation',
    permission: 'Op Level 2+',
    permissionLevel: 'admin',
    syntax: '/sim_status [player]',
    arguments: [
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player. Defaults to caller.' }
    ],
    description: 'Prints a live snapshot of the target player\'s simulation: type, phase, time remaining, fires extinguished.',
    whenToUse: ['Instructor monitoring a student\'s session in real time.']
  },
  {
    name: '/sim_list',
    category: 'simulation',
    permission: 'Op Level 2+',
    permissionLevel: 'admin',
    syntax: '/sim_list',
    description: 'Lists all currently active simulations across every online player.',
    whenToUse: ['Overview of who is in a drill when multiple stations are running simultaneously.']
  },
  {
    name: '/sim_freeze',
    category: 'simulation',
    permission: 'Op Level 2+',
    permissionLevel: 'admin',
    syntax: '/sim_freeze [player]',
    arguments: [
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player. Defaults to caller.' }
    ],
    description: 'Pauses the simulation timer without stopping effects (fire/quake still ticks). Good for pausing to give instruction.',
    notes: ['Resume with /sim_unfreeze.']
  },
  {
    name: '/sim_unfreeze',
    category: 'simulation',
    permission: 'Op Level 2+',
    permissionLevel: 'admin',
    syntax: '/sim_unfreeze [player]',
    arguments: [
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player. Defaults to caller.' }
    ],
    description: 'Resumes a frozen simulation timer.',
    whenToUse: ['After /sim_freeze, when ready to continue the timed session.']
  },
  {
    name: '/sim_time',
    category: 'simulation',
    permission: 'Op Level 2+',
    permissionLevel: 'admin',
    syntax: '/sim_time set <seconds> | /sim_time add <seconds>',
    arguments: [
      { name: 'set/add', type: 'string', range: 'set | add', required: 'Yes', description: '"set" replaces remaining time; "add" adds or subtracts seconds.' },
      { name: 'seconds', type: 'integer', range: 'any', required: 'Yes', description: 'Seconds to set or offset.' }
    ],
    description: 'Adjusts the remaining simulation time on the fly.',
    examples: [
      { cmd: '/sim_time set 60', desc: 'Give student exactly 1 minute left' },
      { cmd: '/sim_time add -30', desc: 'Subtract 30 seconds (urgency drill)' },
      { cmd: '/sim_time add 120', desc: 'Add 2 minutes for a struggling student' }
    ]
  },
  {
    name: '/bfp bypass',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp bypass on [player] | /bfp bypass off [player]',
    arguments: [
      { name: 'on/off', type: 'string', range: 'on | off', required: 'Yes', description: 'Enable or disable bypass mode.' },
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player. Defaults to caller.' }
    ],
    description: 'Skips lobby gates (registration, session check, tutorial) for quick testing. Resets on server restart.',
    whenToUse: ['Dev/testing to jump straight into a simulation without going through the tutorial flow.']
  },
  {
    name: '/bfp note',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp note <text>',
    arguments: [
      { name: 'text', type: 'string', range: 'N/A', required: 'Yes', description: 'Observation text to append to the session.' }
    ],
    description: 'Appends an instructor observation note to the active session\'s bfp_notes column in Turso.',
    whenToUse: ['Recording on-the-fly behavioural observations during a drill.']
  },
  {
    name: '/bfp confidence',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp confidence <1-5>',
    arguments: [
      { name: 'rating', type: 'integer', range: '1–5', required: 'Yes', description: 'Instructor-assessed confidence level (1 = very low, 5 = very high).' }
    ],
    description: 'Sets the instructor confidence rating for the active session.',
    whenToUse: ['After observing a student — rate their perceived readiness/composure.']
  },
  {
    name: '/bfp prep_level',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp prep_level <none|low|moderate|high>',
    arguments: [
      { name: 'level', type: 'string', range: 'none | low | moderate | high', required: 'Yes', description: 'Instructor assessment of preparedness level.' }
    ],
    description: 'Records the instructor\'s preparedness assessment in the session row.',
    whenToUse: ['After a drill — qualitative complement to the numeric score.']
  },
  {
    name: '/bfp score',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp score <0-100> [player]',
    arguments: [
      { name: 'score', type: 'integer', range: '0–100', required: 'Yes', description: 'Override score to assign.' },
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player. Defaults to caller.' }
    ],
    description: 'Manually overrides the simulation score for a session.',
    notes: ['The automatic score is calculated from fires extinguished / threshold. Use this to adjust for rubric factors.']
  },
  {
    name: '/bfp pass',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp pass [player]',
    arguments: [
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player. Defaults to caller.' }
    ],
    description: 'Marks the active session as passed (passed=1) in the database.',
    whenToUse: ['Override when the auto pass/fail logic does not match instructor judgement.']
  },
  {
    name: '/bfp fail',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp fail [player]',
    arguments: [
      { name: 'player', type: 'player', range: 'Online players', required: 'No', description: 'Target player. Defaults to caller.' }
    ],
    description: 'Marks the active session as failed (passed=0) in the database.',
    whenToUse: ['Override pass status when a student fails on non-score criteria.']
  },
  {
    name: '/bfp sessions today',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp sessions today',
    description: 'Lists all sessions started today from Turso.',
    whenToUse: ['End-of-day summary or checking who has gone through the drill today.']
  },
  {
    name: '/bfp sessions stats',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp sessions stats',
    description: 'Prints aggregate statistics: total sessions, pass rate, average score, fire vs earthquake breakdown.',
    whenToUse: ['Instructor reporting; quick top-line numbers without opening the dashboard.']
  },
  {
    name: '/bfp sessions search',
    category: 'bfp-admin',
    permission: 'Op or PIN Admin',
    permissionLevel: 'admin',
    syntax: '/bfp sessions search <query>',
    arguments: [
      { name: 'query', type: 'string', range: 'N/A', required: 'Yes', description: 'Partial student name or station account to search.' }
    ],
    description: 'Searches sessions by student name or station account (partial match).',
    whenToUse: ['Locating a specific student\'s records without knowing their exact station.']
  },
  {
    name: '/get_extinguisher',
    category: 'utility',
    permission: 'Any Player',
    permissionLevel: 'player',
    syntax: '/get_extinguisher',
    description: 'Gives an ABC dry-chemical Fire Extinguisher directly into your inventory.',
    whenToUse: [
      'You dropped or lost the extinguisher during a fire simulation.',
      'Testing extinguisher mechanics outside of a simulation.',
      'Demonstrating the PASS technique before a drill.'
    ],
    notes: [
      'Pin starts NOT pulled. Right-click to pull the pin (P in PASS), then right-click again to spray.',
      '300 durability. Can be used any time.'
    ]
  },
  {
    name: '/get_co2_extinguisher',
    category: 'utility',
    permission: 'Any Player',
    permissionLevel: 'player',
    syntax: '/get_co2_extinguisher',
    description: 'Gives a CO2 extinguisher for Class C (electrical) fires directly into your inventory.',
    whenToUse: [
      'Testing CO2 extinguisher against a ComputerBlock with BURNING=true during a CCS_FIRE simulation.',
      'Demonstrating the difference between ABC and CO2 extinguishers.'
    ],
    notes: [
      'Targets ComputerBlock (BURNING→BROKEN). Also suppresses regular fire/soul fire.',
      '200 durability.'
    ]
  },
  {
    name: '/item hazard',
    category: 'utility',
    permission: 'Op Level 2+',
    permissionLevel: 'admin',
    syntax: '/item hazard <name>',
    arguments: [
      { name: 'name', type: 'string', range: 'see list below', required: 'Yes', description: 'Registry name of the hazard prop block to give. Tab-completes all 20 names.' }
    ],
    description: 'Gives a hazard prop block item by registry name. Use for building the new LSPU Emergency Response Training Facility scenario.',
    whenToUse: [
      'Building or decorating the training facility scenario with realistic hazard props.',
      'Testing a specific hazard block\'s particle effects and light level.',
      'Placing blocks in normal (hazardous=false) or hazardous (hazardous=true via /setblock) states.'
    ],
    detailsLabel: 'Available hazard block names (tab-completes in-game):',
    details: [
      'plastic_trash_bin — classroom bin with vape; smoke when hazardous',
      'daisy_chain_extension — overloaded extension cord; electric sparks',
      'woodshop_sawdust_layer — floor sawdust 0–5 accumulation; ash at level 3+',
      'stage_spotlight — overheating theatre light; flame + smoke; light 10',
      'archive_box_stack — flammable document boxes; campfire smoke',
      'dust_choked_pc — PC tower with blocked vents; smoke; light 3',
      'charging_cart — rolling Chromebook cart; electric sparks; light 5',
      'frayed_console_wire — floor AV cable with bare copper; sparks + soul flame',
      'malfunctioning_vending — shorted vending machine; smoke',
      'ceiling_projector — overheating ceiling projector; smoke + lava; light 7',
      'swollen_phone_battery — thermally swollen phone; soul flame gas',
      'damaged_lipo_pack — punctured drone LiPo; campfire smoke',
      'vape_in_iron_locker — locker with vaping device; sparks + smoke',
      'pa_system_backup — PA amp rack with faulty caps; lava sparks; light 8',
      'smartboard_inverter — water-damaged smartboard; water drip particles',
      'unattended_grease_pan — grease fire on stove; flame + smoke; light 10',
      'grease_clogged_hood — kitchen range hood; large smoke (ceiling-mounted)',
      'contaminated_kitchen_bin — oil-rag bin; steam/smoke wisps',
      'jammed_panini_press — panini press with burning food; smoke',
      'commercial_deep_fryer — overheated fryer; flame + smoke + lava; light 12'
    ],
    notes: [
      'Set hazardous state with /setblock: e.g. /setblock ~ ~ ~ berongsmp:plastic_trash_bin[hazardous=true]',
      'All blocks are registered in the "BerongSMP — Hazard Props" creative tab.'
    ]
  },
  {
    name: '/spawn_lspu',
    category: 'utility',
    permission: 'Op Level 2+ only',
    permissionLevel: 'admin',
    syntax: '/spawn_lspu',
    description: 'Spawns the LSPU Library NBT structure at your current position for inspection.',
    whenToUse: [
      'Dev/admin: placing the library at an arbitrary location.',
      'Testing structure generation without a full simulation.'
    ],
    notes: [
      'Permanent world modification — not restored by /sim_stop.',
      'Use /sim_fire library for a full session that restores the arena on end.'
    ]
  }
];

// Config data
const configs = [
  { key: 'simDurationTicks', default: '2400', affects: 'How long any simulation runs (2 min)' },
  { key: 'quakeMagnitude', default: '5.0', affects: 'Default magnitude for /sim_earthquake with no arg' },
  { key: 'quakeRumbleDuration', default: '100 ticks', affects: 'Length of RUMBLE phase (5 s)' },
  { key: 'quakePeakDuration', default: '200 ticks', affects: 'Length of PEAK phase (10 s)' },
  { key: 'quakeAftershockDuration', default: '100 ticks', affects: 'Length of AFTERSHOCK phase (5 s)' },
  { key: 'quakeBreakCount', default: '2', affects: 'Blocks destroyed per quake interval' },
  { key: 'quakeInterval', default: '10 ticks', affects: 'How often earthquake effect fires' },
  { key: 'fireSpawnCount', default: '3', affects: 'Fire blocks placed per spawn interval' },
  { key: 'fireSpawnInterval', default: '20 ticks', affects: 'How often fire is placed (1 s)' },
  { key: 'tursoUrl', default: '""', affects: 'Turso HTTPS database URL for session tracking' },
  { key: 'tursoToken', default: '""', affects: 'Turso Bearer auth token' },
  { key: 'passThresholdFire', default: '5', affects: 'Fires extinguished required to mark a session as passed' },
  { key: 'bfpAdminPin', default: '""', affects: 'PIN for /bfp login — empty string disables PIN auth (OP-only); set a PIN before going live' },
  { key: 'quakeDecayRate', default: '0.05', affects: 'Intensity falloff per block of distance from epicenter' },
  { key: 'quakeRumbleDuration', default: '200', affects: 'Ticks in RUMBLE phase (10 s)' },
  { key: 'quakePeakDuration', default: '900', affects: 'Ticks in PEAK phase (45 s)' },
  { key: 'quakeAftershockDuration', default: '300', affects: 'Ticks per aftershock wave (15 s)' },
  { key: 'simAreaSize', default: '25', affects: 'XZ arena radius for random fire/quake effects' },
  { key: 'simAreaHeight', default: '10', affects: 'Y arena height for random effects' }
];
---

<DashboardLayout title="Commands Reference" currentPath="/commands">
  <!-- Page Header -->
  <div class="page-header flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
      <h1 class="page-title">Commands Reference</h1>
      <p class="page-meta">Registered by ModCommands.java · hot-reloadable server configuration</p>
    </div>
    <!-- Search Bar -->
    <div class="search-container">
      <span class="material-symbols-outlined search-icon">search</span>
      <input
        type="text"
        id="command-search"
        placeholder="Search commands, syntax, keywords..."
        autocomplete="off"
      />
    </div>
  </div>

  <!-- Filter & Statistics Bar -->
  <div class="filter-bar">
    <div class="filter-group">
      <span class="filter-label">Categories</span>
      <div class="filter-pills" id="category-filters">
        <button class="filter-pill active" data-category="all">ALL</button>
        <button class="filter-pill" data-category="simulation">SIMULATION</button>
        <button class="filter-pill" data-category="earthquake">EARTHQUAKE</button>
        <button class="filter-pill" data-category="bfp-admin">BFP ADMIN</button>
        <button class="filter-pill" data-category="utility">UTILITY</button>
      </div>
