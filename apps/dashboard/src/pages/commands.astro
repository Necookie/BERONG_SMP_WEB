<script>
  // Client-side interactions
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('command-search') as HTMLInputElement | null;
    const categoryButtons = document.querySelectorAll('#category-filters .filter-pill');
    const commandCards = document.querySelectorAll('.command-card') as NodeListOf<HTMLDivElement>;
    const filteredCount = document.getElementById('filtered-count');
    const noResultsMessage = document.getElementById('no-results-message');

    let activeCategory = 'all';
    let searchQuery = '';

    // Handle searching and filtering cards
    function filterCommands() {
      let count = 0;

      commandCards.forEach((card) => {
        const category = card.dataset.category || '';
        const keywords = (card.dataset.keywords || '').toLowerCase();
        
        const matchesCategory = activeCategory === 'all' || category === activeCategory;
        const matchesSearch = keywords.includes(searchQuery.toLowerCase());

        if (matchesCategory && matchesSearch) {
          card.style.display = 'block';
          count++;
        } else {
          card.style.display = 'none';
        }
      });

      if (filteredCount) {
        filteredCount.textContent = count.toString();
      }

      if (noResultsMessage) {
        if (count === 0) {
          noResultsMessage.classList.remove('hidden');
        } else {
          noResultsMessage.classList.add('hidden');
        }
      }
    }

    // Search input listener
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.trim();
        filterCommands();
      });
    }

    // Category filter pills listener
    categoryButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        categoryButtons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.getAttribute('data-category') || 'all';
        filterCommands();
      });
    });

    // Copy to clipboard listener
    const copyButtons = document.querySelectorAll('.copy-btn');
    copyButtons.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const syntax = btn.getAttribute('data-syntax') || '';
        if (!syntax) return;

        try {
          await navigator.clipboard.writeText(syntax);
          
          // Visual Feedback
          const label = btn.querySelector('.label');
          const icon = btn.querySelector('.icon');
          
          if (label && icon) {
            const originalText = label.textContent;
            const originalIcon = icon.textContent;

            label.textContent = 'Copied!';
            icon.textContent = 'done';
            btn.classList.add('success-state');

            setTimeout(() => {
              label.textContent = originalText;
              icon.textContent = originalIcon;
              btn.classList.remove('success-state');
            }, 1800);
          }
        } catch (err) {
          console.error('Failed to copy to clipboard', err);
        }
      });
    });

    // Details Toggle (Accordion) listener
    const toggleButtons = document.querySelectorAll('.details-toggle');
    toggleButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = btn.closest('.command-card');
        if (!card) return;

        const content = card.querySelector('.details-content') as HTMLDivElement | null;
        const icon = btn.querySelector('.toggle-icon');
        const textSpan = btn.querySelector('span:first-child');

        if (content && icon && textSpan) {
          const isCollapsed = content.classList.contains('hidden-height');
          
          if (isCollapsed) {
            // Expand
            content.classList.remove('hidden-height');
            icon.classList.add('active');
            textSpan.textContent = 'Hide Details';
            
            // Allow height calculation transitions
            content.style.maxHeight = '1000px'; 
            content.style.opacity = '1';
            content.style.pointerEvents = 'auto';
          } else {
            // Collapse
            content.classList.add('hidden-height');
            icon.classList.remove('active');
            textSpan.textContent = 'View Details';
            
            content.style.maxHeight = '0px';
            content.style.opacity = '0';
            content.style.pointerEvents = 'none';
          }
        }
      });
    });
  });
</script>
