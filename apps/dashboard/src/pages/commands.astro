                      {cmd.whenToUse.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}

                {cmd.whatHappens && (
                  <div class="detail-block">
                    <span class="sub-label">What happens:</span>
                    <ol>
                      {cmd.whatHappens.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ol>
                  </div>
                )}

                {cmd.details && (
                  <div class="detail-block">
                    <span class="sub-label">{cmd.detailsLabel ?? 'Information printed:'}</span>
                    <ul>
                      {cmd.details.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}

                {cmd.examples && (
                  <div class="detail-block">
                    <span class="sub-label">Example flow:</span>
                    <div class="example-box">
                      {cmd.examples.map((ex) => (
