                {cmd.notes && (
                  <div class="detail-block">
                    <span class="sub-label">Notes:</span>
                    <ul class="notes-list">
                      {cmd.notes.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

