---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import {
  sessions,
  getRecentSessions,
  getTierCounts,
  getAvgScore,
  getScenarioSplit,
  getSessionsThisWeek,
  formatDuration,
  formatDate,
} from '../lib/mockData.ts';

const tiers     = getTierCounts();
const avgScore  = getAvgScore();
const split     = getScenarioSplit();
const thisWeek  = getSessionsThisWeek();
const recent    = getRecentSessions(5);

const highPct     = Math.round((tiers.high     / tiers.total) * 100);
const moderatePct = Math.round((tiers.moderate / tiers.total) * 100);
const lowPct      = 100 - highPct - moderatePct;
---

<DashboardLayout title="Overview" currentPath="/">

  <!-- Page header -->
  <div class="page-header">
    <h1 class="page-title">Overview</h1>
    <p class="page-meta">June 2026 cohort · LSPU DRR Training Programme · data: mock</p>
  </div>

  <!-- KPI strip -->
  <div class="kpi-strip">
    <div class="kpi-item">
      <span class="kpi-label">Total Sessions</span>
      <span class="kpi-value">{tiers.total}</span>
    </div>
    <div class="kpi-item">
      <span class="kpi-label">Avg. Preparedness</span>
      <span class="kpi-value">{avgScore}<span class="kpi-unit">%</span></span>
    </div>
    <div class="kpi-item">
      <span class="kpi-label">Scenario split</span>
      <div class="kpi-split">
        <span style="color: #88d982;">{split.fire}</span>
        <span style="color: #2a2a2a;"> / </span>
        <span style="color: #bfcaba;">{split.eq}</span>
      </div>
      <p class="kpi-split-label">
        <span style="color: #88d982;">FIRE</span>
        &nbsp;/&nbsp;
        <span style="color: #bfcaba;">EARTHQUAKE</span>
      </p>
    </div>
    <div class="kpi-item">
      <span class="kpi-label">This week</span>
      <span class="kpi-value">{thisWeek}</span>
    </div>
  </div>

  <!-- Distribution bar -->
  <div class="dist-section">
    <div class="dist-head">
      <span class="section-label">Preparedness distribution</span>
      <span class="dist-cohort">{tiers.total} sessions</span>
    </div>
    <div class="dist-bar">
      <div class="dist-seg high"     style={`width: ${highPct}%`}></div>
      <div class="dist-seg moderate" style={`width: ${moderatePct}%`}></div>
      <div class="dist-seg low"      style={`width: ${lowPct}%`}></div>
    </div>
    <div class="dist-legend">
      <div class="dist-leg-item">
        <span class="leg-dot high"></span>
        <span class="leg-tier high">HIGH</span>
        <span class="leg-count">{tiers.high} sessions · {highPct}%</span>
      </div>
      <div class="dist-leg-item">
        <span class="leg-dot moderate"></span>
        <span class="leg-tier moderate">MODERATE</span>
        <span class="leg-count">{tiers.moderate} sessions · {moderatePct}%</span>
      </div>
      <div class="dist-leg-item">
        <span class="leg-dot low"></span>
        <span class="leg-tier low">LOW</span>
        <span class="leg-count">{tiers.low} sessions · {lowPct}%</span>
      </div>
    </div>
  </div>

  <!-- Recent sessions -->
  <div class="sessions-section">
    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16px;">
      <span class="section-label">Recent sessions</span>
      <a href="/sessions" class="view-link">View all →</a>
    </div>
    <table class="sessions-table">
      <thead>
        <tr>
          <th>Participant</th>
          <th>Scenario</th>
          <th>Date</th>
          <th>Duration</th>
          <th>Level</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {recent.map(s => (
          <tr onclick={`window.location='/sessions/${s.id}'`}>
            <td class="name-cell">{s.participantName}</td>
            <td>
              <span style={`font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; color:${s.disasterType === 'FIRE' ? '#88d982' : '#bfcaba'};`}>
                {s.disasterType}
              </span>
            </td>
            <td style="font-family:'JetBrains Mono',monospace; font-size:11px;">{formatDate(s.startTime)}</td>
            <td style="font-family:'JetBrains Mono',monospace; font-size:11px;">{formatDuration(s.durationSeconds)}</td>
            <td>
              <span class={`tier-badge ${s.prepLevel.toLowerCase()}`}>
                <span class="dot"></span>
                {s.prepLevel}
              </span>
            </td>
            <td class="link-cell">
              <a href={`/sessions/${s.id}`} class="view-link" onclick="event.stopPropagation()">→</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

</DashboardLayout>
