---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import ErrorCard from '../components/ErrorCard.astro';
import PrepChart from '../components/PrepChart';
import ScoreHistogram from '../components/ScoreHistogram';
import {
  getOverviewStats,
  getRecentSessions,
  getAllCompletedScores,
  formatDate,
  formatDuration,
  derivePrepLevel,
} from '../lib/queries';
import { getEnv } from '../lib/db';

const env = await getEnv();
const hasDb = !!env;

let stats = { total: 0, avg_score: 0, fire_count: 0, quake_count: 0, this_week: 0, high_count: 0, mod_count: 0, low_count: 0 };
let recent: Awaited<ReturnType<typeof getRecentSessions>> = [];
let scores: number[] = [];

let dbError: string | null = null;

if (env) {
  try {
    [stats, recent, scores] = await Promise.all([
      getOverviewStats(env),
      getRecentSessions(env, 5),
      getAllCompletedScores(env),
    ]);
  } catch (err) {
    dbError = err instanceof Error ? err.message : 'Unknown database error';
  }
}

const totalWithLevel = stats.high_count + stats.mod_count + stats.low_count;
const highPct     = totalWithLevel ? Math.round((stats.high_count / totalWithLevel) * 100) : 0;
const moderatePct = totalWithLevel ? Math.round((stats.mod_count  / totalWithLevel) * 100) : 0;
const lowPct      = 100 - highPct - moderatePct;
---

<DashboardLayout title="Overview" currentPath="/">

  <div class="page-header">
    <h1 class="page-title">Overview</h1>
    <p class="page-meta">
      LSPU DRR Training Programme · {hasDb ? (dbError ? '⚠ DB error' : 'live data') : '⚠ no DB configured'}
    </p>
  </div>

  {dbError && <ErrorCard message={dbError} />}

  <div class="kpi-strip">
    <div class="kpi-item kpi-item--primary">
      <span class="kpi-label">Avg. Score</span>
      <span class="kpi-value">{stats.avg_score}<span class="kpi-unit">%</span></span>
    </div>
    <div class="kpi-item kpi-item--secondary">
      <span class="kpi-label">Scenario split</span>
      <div class="kpi-split">
        <span style="color: var(--color-fire);">{stats.fire_count}</span>
        <span style="color: var(--color-separator);"> / </span>
        <span style="color: var(--color-earthquake);">{stats.quake_count}</span>
      </div>
      <p class="kpi-split-label">
        <span style="color: var(--color-fire);">FIRE</span>
        &nbsp;/&nbsp;
        <span style="color: var(--color-earthquake);">EARTHQUAKE</span>
      </p>
    </div>
    <div class="kpi-item kpi-item--secondary">
      <span class="kpi-label">Total Sessions</span>
      <span class="kpi-value">{stats.total}</span>
    </div>
    <div class="kpi-item kpi-item--secondary">
      <span class="kpi-label">This week</span>
      <span class="kpi-value">{stats.this_week}</span>
    </div>
  </div>

  <div class="dist-section dist-section--grid">
    <div>
      <div class="dist-head">
        <span class="section-label">Preparedness distribution</span>
        <span class="dist-cohort">{totalWithLevel} classified sessions</span>
      </div>
      <div class="dist-chart-row">
        <div class="dist-chart-wrap">
          <PrepChart client:only="react" high={stats.high_count} moderate={stats.mod_count} low={stats.low_count} />
        </div>
        <div class="dist-legend dist-legend--stacked">
          <div class="dist-leg-item">
            <span class="leg-dot high"></span>
            <span class="leg-tier high">HIGH</span>
            <span class="leg-count">{stats.high_count} · {highPct}%</span>
          </div>
          <div class="dist-leg-item">
            <span class="leg-dot moderate"></span>
            <span class="leg-tier moderate">MODERATE</span>
            <span class="leg-count">{stats.mod_count} · {moderatePct}%</span>
          </div>
          <div class="dist-leg-item">
            <span class="leg-dot low"></span>
            <span class="leg-tier low">LOW</span>
            <span class="leg-count">{stats.low_count} · {lowPct}%</span>
          </div>
        </div>
      </div>
    </div>
    <div>
      <div class="dist-head">
        <span class="section-label">Score distribution</span>
        <span class="dist-cohort">All completed sessions</span>
      </div>
      <div class="dist-histogram-wrap">
        <ScoreHistogram client:only="react" scores={scores} />
      </div>
    </div>
  </div>

  <div class="sessions-section">
    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16px; flex-wrap: wrap; gap: 8px;">
      <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
        <span class="section-label">Recent sessions</span>
        <span class="live-indicator" id="live-indicator" style="display: none; align-items: center; gap: 4px; font-family: 'JetBrains Mono', monospace; font-size: 9px; color: #88d982; border: 1px solid rgba(136, 217, 130, 0.3); padding: 2px 6px; border-radius: 4px;">
          <span class="live-dot" style="width: 5px; height: 5px; background: #88d982; border-radius: 50%; display: inline-block;"></span>
          LIVE POLLING
        </span>
        <span id="last-updated" style="font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--text-muted); display: none;"></span>
      </div>
      <a href="/sessions" class="view-link">View all →</a>
    </div>

    {recent.length === 0 ? (
      <p class="td-no-data" style="padding:24px 0; text-align:center;">
        {hasDb ? 'No completed sessions yet.' : 'Configure TURSO_URL and TURSO_TOKEN in .dev.vars to see live data.'}
      </p>
    ) : (
      <div class="table-scroll-wrap">
        <table class="sessions-table">
          <thead>
            <tr>
              <th class="sortable" data-sort-key="student">Student</th>
              <th class="sortable" data-sort-key="section">Section</th>
              <th class="sortable" data-sort-key="scenario">Scenario</th>
              <th class="sortable" data-sort-key="date">Date</th>
              <th class="sortable" data-sort-key="duration">Duration</th>
              <th class="sortable" data-sort-key="score">Score</th>
              <th class="sortable" data-sort-key="level">Level</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {recent.map(s => {
              const level = derivePrepLevel(s.simulation_score, s.prep_level);
              const durationMs = s.start_time && s.end_time 
                ? new Date(s.end_time).getTime() - new Date(s.start_time).getTime() 
                : 0;
              return (
                <tr
                  data-sort-student={s.student_name.toLowerCase()}
                  data-sort-section={(s.section ?? '').toLowerCase()}
                  data-sort-scenario={(s.simulation_type ?? 'UNKNOWN').toLowerCase()}
                  data-sort-date={s.start_time ? new Date(s.start_time).getTime() : 0}
                  data-sort-duration={durationMs}
                  data-sort-score={s.simulation_score}
                  data-sort-level={level === 'HIGH' ? 3 : level === 'MODERATE' ? 2 : level === 'LOW' ? 1 : 0}
                  onclick={`window.location='/sessions/${s.id}'`}
                >
                  <td class="name-cell">{s.student_name}</td>
                  <td class="td-mono-muted">{s.section ?? '—'}</td>
                  <td>
                    <span class={s.simulation_type === 'FIRE' ? 'td-type-fire' : 'td-type-quake'}>
                      {s.simulation_type ?? '—'}
                    </span>
                  </td>
                  <td class="td-mono-muted">{formatDate(s.start_time)}</td>
                  <td class="td-mono-muted">{formatDuration(s.start_time, s.end_time)}</td>
                  <td class="td-score">{s.simulation_score}</td>
                  <td>
                    {level !== 'PENDING' ? (
                      <span class={`tier-badge ${level.toLowerCase()}`}>
                        <span class="dot"></span>
                        {level}
                      </span>
                    ) : (
                      <span class="td-pending">PENDING</span>
                    )}
                  </td>
                  <td class="link-cell">
                    <a href={`/sessions/${s.id}`} class="view-link" onclick="event.stopPropagation()">→</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>

</DashboardLayout>

<script>
  import { initTableSorting } from '../lib/tableSorter';
  initTableSorting();

  // KPI count-up animation
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const els = document.querySelectorAll('.kpi-value');
    els.forEach(function (el) {
      const textNode = Array.from(el.childNodes).find(function (n) {
        return n.nodeType === 3 && n.textContent.trim();
      });
      if (!textNode) return;
      const target = parseFloat(textNode.textContent.trim());
      if (!Number.isFinite(target) || target === 0) return;
      const start = performance.now();
      const duration = 600;
      textNode.textContent = '0';
      function tick(now) {
        const t = Math.min((now - start) / duration, 1);
        const eased = t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
        textNode.textContent = Math.round(eased * target).toString();
        if (t < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    });
  })();

  const indicator = document.getElementById('live-indicator');
  const lastUpdatedEl = document.getElementById('last-updated');
  const tableBody = document.querySelector('.sessions-table tbody');

  // Add styles for live dot pulse
  const style = document.createElement('style');
  style.textContent = `
    @keyframes live-pulse {
      0% { transform: scale(0.95); opacity: 0.5; }
      50% { transform: scale(1.1); opacity: 1; }
      100% { transform: scale(0.95); opacity: 0.5; }
    }
    .live-dot {
      animation: live-pulse 1.5s infinite ease-in-out;
    }
  `;
  document.head.appendChild(style);

  if (indicator && tableBody) {
    indicator.style.display = 'inline-flex';
  }

  let lastUpdatedTime = Date.now();
  
  function updateTimeLabel() {
    if (!lastUpdatedEl) return;
    const diff = Math.round((Date.now() - lastUpdatedTime) / 1000);
    if (diff < 5) {
      lastUpdatedEl.textContent = '· Just now';
    } else if (diff < 60) {
      lastUpdatedEl.textContent = `· Updated ${diff}s ago`;
    } else {
      const mins = Math.floor(diff / 60);
      lastUpdatedEl.textContent = `· Updated ${mins}m ago`;
    }
    lastUpdatedEl.style.display = 'inline';
  }

  // Formatting helpers for rendering
  function formatDurationLocal(start, end) {
    if (!end) return '—';
    const secs = Math.round((new Date(end).getTime() - new Date(start).getTime()) / 1000);
    const m = Math.floor(secs / 60);
    const s = secs % 60;
    return `${m}m ${s.toString().padStart(2, '0')}s`;
  }

  function formatDateLocal(iso) {
    return new Date(iso).toLocaleDateString('en-PH', {
      month: 'short', day: 'numeric', year: 'numeric'
    });
  }

  function derivePrepLevelLocal(score, stored) {
    if (stored) return stored;
    if (score >= 75) return 'HIGH';
    if (score >= 40) return 'MODERATE';
    return 'LOW';
  }

  async function pollLatest() {
    if (!tableBody) return;
    try {
      const res = await fetch('/api/sessions/latest');
      if (!res.ok) return;
      const data = await res.json();
      
      if (!Array.isArray(data)) return;
      
      lastUpdatedTime = Date.now();
      updateTimeLabel();

      tableBody.innerHTML = '';
      data.forEach(s => {
        const level = derivePrepLevelLocal(s.simulation_score, s.prep_level);
        const tierClass = level !== 'PENDING' ? level.toLowerCase() : 'low';
        const durationMs = s.start_time && s.end_time 
          ? new Date(s.end_time).getTime() - new Date(s.start_time).getTime() 
          : 0;

        const tr = document.createElement('tr');
        tr.setAttribute('data-sort-student', s.student_name.toLowerCase());
        tr.setAttribute('data-sort-section', (s.section ?? '').toLowerCase());
        tr.setAttribute('data-sort-scenario', (s.simulation_type ?? 'UNKNOWN').toLowerCase());
        tr.setAttribute('data-sort-date', s.start_time ? new Date(s.start_time).getTime().toString() : '0');
        tr.setAttribute('data-sort-duration', durationMs.toString());
        tr.setAttribute('data-sort-score', s.simulation_score.toString());
        tr.setAttribute('data-sort-level', level === 'HIGH' ? '3' : level === 'MODERATE' ? '2' : level === 'LOW' ? '1' : '0');
        
        tr.onclick = () => { window.location.href = `/sessions/${s.id}`; };
        tr.style.cursor = 'pointer';

        tr.innerHTML = `
          <td class="name-cell">${s.student_name}</td>
          <td class="td-mono-muted">${s.section ?? '—'}</td>
          <td>
            <span class="${s.simulation_type === 'FIRE' ? 'td-type-fire' : 'td-type-quake'}">
              ${s.simulation_type ?? '—'}
            </span>
          </td>
          <td class="td-mono-muted">${formatDateLocal(s.start_time)}</td>
          <td class="td-mono-muted">${formatDurationLocal(s.start_time, s.end_time)}</td>
          <td class="td-score">${s.simulation_score}</td>
          <td>
            \${level !== 'PENDING' ? \`
              <span class="tier-badge \${tierClass}">
                <span class="dot"></span>
                \${level}
              </span>
            \` : \`
              <span class="td-pending">PENDING</span>
            \`}
          </td>
          <td class="link-cell">
            <a href="/sessions/\${s.id}" class="view-link">→</a>
          </td>
        `;
        
        const a = tr.querySelector('.view-link');
        if (a) {
          a.onclick = (e) => { e.stopPropagation(); };
        }

        tableBody.appendChild(tr);
      });

    } catch (err) {
      console.error('Polling error:', err);
    }
  }

  if (tableBody) {
    setInterval(updateTimeLabel, 5000);
    setInterval(pollLatest, 15000);
    updateTimeLabel();
  }
</script>
