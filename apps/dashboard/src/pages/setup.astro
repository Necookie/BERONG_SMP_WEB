---
import '../styles/global.css';
import { getEnv } from '../lib/db';
import { hasAnyUsers } from '../lib/queries';
import { Image } from 'astro:assets';
import logo from '../assets/images/berong-elearning-logo.png';
import ThemeToggle from '../components/ThemeToggle';

const env = await getEnv();
if (!env) {
  return Astro.redirect('/error');
}

// Redirect to login if users already exist
const usersExist = await hasAnyUsers(env);
if (usersExist) {
  return Astro.redirect('/login');
}
---

<!doctype html>
<html lang="en">
<head>
  <script is:inline>
    (function () {
      const stored = localStorage.getItem('theme');
      const prefersDark =
        stored === 'dark' ||
        (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
      document.documentElement.classList.add(prefersDark ? 'dark' : 'light');
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Setup Admin Account — BERONG SMP</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
    rel="stylesheet"
  />
</head>
<body class="bg-base min-h-screen flex items-center justify-center p-4">
  <div class="setup-wrapper w-full max-w-md">
    <div class="theme-toggle-container flex justify-end mb-4">
      <ThemeToggle client:only="react" />
    </div>
    
    <div class="card p-8 border border-card bg-card rounded-lg shadow-xl">
      <div class="flex flex-col items-center mb-6">
        <Image
          src={logo}
          alt="BERONG SMP logo"
          class="w-16 h-16 object-contain mb-3"
          width={64}
          height={64}
          format="webp"
          quality={85}
        />
        <h1 class="text-2xl font-semibold font-display text-heading">Setup Admin</h1>
        <p class="text-sm text-secondary mt-1">Create the initial administrator account</p>
      </div>

      <div id="error-message" class="hidden p-3 bg-red-950/40 border border-red-900 text-red-400 text-sm rounded mb-4 text-center"></div>
      <div id="success-message" class="hidden p-3 bg-emerald-950/40 border border-emerald-900 text-emerald-400 text-sm rounded mb-4 text-center"></div>

      <form id="setup-form" class="space-y-4">
        <div>
          <label for="username" class="block text-xs font-semibold uppercase tracking-wider text-secondary mb-1">Username</label>
          <input
            type="text"
            id="username"
            name="username"
            required
            autocomplete="username"
            class="w-full bg-base border border-card rounded px-3 py-2 text-primary focus:outline-none focus:border-brand transition-colors"
          />
        </div>
        <div>
          <label for="password" class="block text-xs font-semibold uppercase tracking-wider text-secondary mb-1">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="new-password"
            class="w-full bg-base border border-card rounded px-3 py-2 text-primary focus:outline-none focus:border-brand transition-colors"
          />
        </div>
        <div>
          <label for="confirm-password" class="block text-xs font-semibold uppercase tracking-wider text-secondary mb-1">Confirm Password</label>
          <input
            type="password"
            id="confirm-password"
            name="confirmPassword"
            required
            autocomplete="new-password"
            class="w-full bg-base border border-card rounded px-3 py-2 text-primary focus:outline-none focus:border-brand transition-colors"
          />
        </div>
        <button
          type="submit"
          class="w-full bg-brand text-black font-semibold rounded py-2 hover:opacity-90 transition-opacity mt-2"
        >
          Initialize Administrator
        </button>
      </form>
    </div>
  </div>

  <style>
    body {
      background-color: var(--bg-base);
      color: var(--text-primary);
      font-family: 'Inter', sans-serif;
    }
    .font-display {
      font-family: 'Space Grotesk', sans-serif;
    }
    .text-heading {
      color: var(--text-heading);
    }
    .text-secondary {
      color: var(--text-secondary);
    }
    .card {
      background-color: var(--bg-card);
      border-color: var(--border-card);
    }
    .bg-base {
      background-color: var(--bg-base);
    }
    .border-card {
      border-color: var(--border-card);
    }
    .focus\:border-brand:focus {
      border-color: var(--text-brand);
      box-shadow: 0 0 0 2px rgba(136, 217, 130, 0.2);
    }
    .bg-brand {
      background-color: var(--text-brand);
      color: var(--bg-base);
    }
    :global(html.light) .bg-brand {
      color: #ffffff;
    }
  </style>

  <script>
    const form = document.getElementById('setup-form') as HTMLFormElement;
    const errorDiv = document.getElementById('error-message') as HTMLDivElement;
    const successDiv = document.getElementById('success-message') as HTMLDivElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!errorDiv || !successDiv) return;
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');
      errorDiv.textContent = '';
      successDiv.textContent = '';

      const formData = new FormData(form);
      const username = formData.get('username')?.toString().trim();
      const password = formData.get('password')?.toString();
      const confirmPassword = formData.get('confirmPassword')?.toString();

      if (!username || !password || !confirmPassword) {
        errorDiv.textContent = 'Please fill out all fields';
        errorDiv.classList.remove('hidden');
        return;
      }

      if (password !== confirmPassword) {
        errorDiv.textContent = 'Passwords do not match';
        errorDiv.classList.remove('hidden');
        return;
      }

      try {
        const res = await fetch('/api/auth/setup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password }),
        });

        const data = await res.json() as any;
        if (res.ok && data.ok) {
          successDiv.textContent = 'Administrator account created successfully! Redirecting...';
          successDiv.classList.remove('hidden');
          setTimeout(() => {
            window.location.href = '/login';
          }, 1500);
        } else {
          errorDiv.textContent = data.error || 'Setup failed';
          errorDiv.classList.remove('hidden');
        }
      } catch (err) {
        errorDiv.textContent = 'An unexpected connection error occurred';
        errorDiv.classList.remove('hidden');
      }
    });
  </script>
</body>
</html>
