---
import '../styles/global.css';
import { getEnv } from '../lib/db';
import { hasAnyUsers } from '../lib/queries';
import { Image } from 'astro:assets';
import logo from '../assets/images/berong-elearning-logo.png';
import ThemeToggle from '../components/ThemeToggle';

const env = await getEnv();
if (!env) {
  return Astro.redirect('/error');
}

// Redirect to login if users already exist
const usersExist = await hasAnyUsers(env);
if (usersExist) {
  return Astro.redirect('/login');
}
---

<!doctype html>
<html lang="en">
<head>
  <script is:inline>
    (function () {
      const stored = localStorage.getItem('theme');
      const prefersDark =
        stored === 'dark' ||
        (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
      document.documentElement.classList.add(prefersDark ? 'dark' : 'light');
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Setup Admin Account — BERONG SMP</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
    rel="stylesheet"
  />
</head>
<body class="bg-base min-h-screen flex items-center justify-center py-12 px-4 relative">
  <!-- Glowing decorative blobs -->
  <div class="absolute top-[-10%] right-[-10%] w-[50vw] h-[50vw] bg-brand/5 rounded-full blur-[120px] pointer-events-none -z-10"></div>
  <div class="absolute bottom-[-10%] left-[-10%] w-[50vw] h-[50vw] bg-brand/5 rounded-full blur-[120px] pointer-events-none -z-10"></div>

  <!-- Float ThemeToggle in the top-right corner -->
  <div class="absolute top-4 right-4 z-20">
    <div class="glass-toggle p-1 rounded-full border border-card/40 bg-card/30 backdrop-blur-md shadow-sm">
      <ThemeToggle client:only="react" />
    </div>
  </div>

  <div class="setup-wrapper w-full max-w-[460px] relative z-10">
    
    <div class="card p-6 sm:p-8 md:p-10 border border-card bg-card shadow-2xl relative overflow-hidden">
      <!-- Glow border effect -->
      <div class="absolute inset-0 border border-white/5 pointer-events-none" style="border-radius: var(--radius-modal);"></div>

      <div class="flex flex-col items-center mb-8">
        <div class="logo-box p-4 bg-base/50 border border-card/60 mb-4 shadow-inner flex items-center justify-center">
          <img
            src={logo.src}
            alt="BERONG SMP logo"
            class="w-12 h-12 object-contain"
            width="48"
            height="48"
          />
        </div>
        <span class="setup-badge px-3 py-1 text-[10px] font-bold tracking-widest uppercase mb-3">
          Secure initialization
        </span>
        <h1 class="text-3xl font-bold font-display text-heading tracking-tight">Setup Admin</h1>
        <p class="text-sm text-secondary mt-2 text-center max-w-[280px]">Create the initial administrator account to unlock dashboard access</p>
      </div>

      <div id="error-message" class="hidden p-3 bg-red-950/40 border border-red-900/60 text-red-400 text-sm mb-4 text-center backdrop-blur-sm"></div>
      <div id="success-message" class="hidden p-3 bg-emerald-950/40 border border-emerald-900/60 text-emerald-400 text-sm mb-4 text-center backdrop-blur-sm"></div>

      <form id="setup-form" class="space-y-5">
        <div>
          <label for="username" class="block text-[11px] font-semibold uppercase tracking-wider text-secondary mb-1.5">Username</label>
          <div class="input-wrapper relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-secondary pointer-events-none text-[20px] transition-all duration-300">person</span>
            <input
              type="text"
              id="username"
              name="username"
              required
              autocomplete="username"
              placeholder="e.g. admin"
              class="w-full bg-base border border-card pl-11 pr-4 py-3 text-primary focus:outline-none focus:border-brand transition-all duration-300 placeholder-muted"
            />
          </div>
        </div>
        <div>
          <label for="password" class="block text-[11px] font-semibold uppercase tracking-wider text-secondary mb-1.5">Password</label>
          <div class="input-wrapper relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-secondary pointer-events-none text-[20px] transition-all duration-300">lock</span>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="new-password"
              placeholder="••••••••"
              class="w-full bg-base border border-card pl-11 pr-11 py-3 text-primary focus:outline-none focus:border-brand transition-all duration-300 placeholder-muted"
            />
            <button type="button" class="pwd-toggle absolute right-3 top-1/2 -translate-y-1/2" aria-label="Toggle password visibility">
              <span class="material-symbols-outlined">visibility</span>
            </button>
          </div>
        </div>
        <div>
          <label for="confirm-password" class="block text-[11px] font-semibold uppercase tracking-wider text-secondary mb-1.5">Confirm Password</label>
          <div class="input-wrapper relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-secondary pointer-events-none text-[20px] transition-all duration-300">lock_reset</span>
            <input
              type="password"
              id="confirm-password"
              name="confirmPassword"
              required
              autocomplete="new-password"
              placeholder="••••••••"
              class="w-full bg-base border border-card pl-11 pr-11 py-3 text-primary focus:outline-none focus:border-brand transition-all duration-300 placeholder-muted"
            />
            <button type="button" class="pwd-toggle absolute right-3 top-1/2 -translate-y-1/2" aria-label="Toggle password visibility">
              <span class="material-symbols-outlined">visibility</span>
            </button>
          </div>
        </div>
        
        <button
          type="submit"
          class="w-full bg-brand text-white font-semibold py-3 shadow-[0_4px_0_#9b1c1c] hover:-translate-y-0.5 hover:shadow-[0_6px_0_#9b1c1c] active:translate-y-1 active:shadow-[0_0px_0_#9b1c1c] transition-all duration-100 mt-3"
        >
          Initialize Administrator
        </button>
      </form>
    </div>
  </div>

  <style>
    html, body {
      overflow-x: hidden;
      margin: 0;
      padding: 0;
    }
    body {
      background-color: var(--bg-base);
      color: var(--text-primary);
      font-family: 'Inter', sans-serif;
    }
    .font-display {
      font-family: 'Space Grotesk', sans-serif;
    }
    .text-heading {
      color: var(--text-heading);
    }
    .text-secondary {
      color: var(--text-secondary);
    }
    .placeholder-muted::placeholder {
      color: var(--text-muted);
      opacity: 0.5;
    }
    .card {
      background-color: rgba(17, 17, 17, 0.75);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: var(--radius-modal);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.02);
    }
    .logo-box {
      background-color: rgba(13, 13, 13, 0.8);
      border-color: rgba(255, 255, 255, 0.08);
      border-radius: var(--radius-card);
    }
    .setup-badge {
      background: rgba(229, 57, 53, 0.08);
      color: var(--text-brand);
      border: 1px solid rgba(229, 57, 53, 0.15);
      border-radius: var(--radius-badge);
    }
    .bg-base {
      background-color: rgba(13, 13, 13, 0.7);
      border-color: rgba(255, 255, 255, 0.08);
      border-radius: var(--radius-input);
    }
    #error-message, #success-message {
      border-radius: var(--radius-card);
    }
    input:focus {
      border-color: var(--text-brand) !important;
      box-shadow: 0 0 0 3px rgba(229, 57, 53, 0.15);
    }
    .input-wrapper:focus-within span {
      color: var(--text-brand) !important;
      opacity: 0.9 !important;
    }
    .pwd-toggle {
      background: transparent;
      border: none;
      padding: 0;
      cursor: pointer;
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.15s;
    }
    .pwd-toggle:hover { color: var(--text-brand); }
    .pwd-toggle .material-symbols-outlined { font-size: 18px; pointer-events: none; }
    .bg-brand {
      background-color: var(--text-brand);
      color: #ffffff;
      border: none;
      border-radius: var(--radius-button);
    }
    
    /* Light mode adaptations */
    :global(html.light) .card {
      background-color: rgba(234, 230, 226, 0.85);
      border: 1px solid rgba(0, 0, 0, 0.06);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.02);
    }
    :global(html.light) .logo-box {
      background-color: rgba(244, 241, 238, 0.9);
      border-color: rgba(0, 0, 0, 0.06);
    }
    :global(html.light) .setup-badge {
      background: rgba(220, 38, 38, 0.06);
      color: var(--text-brand);
      border: 1px solid rgba(220, 38, 38, 0.15);
    }
    :global(html.light) .bg-base {
      background-color: rgba(244, 241, 238, 0.8);
      border-color: rgba(0, 0, 0, 0.08);
      color: #1a1a1a;
    }
    :global(html.light) .bg-brand {
      color: #ffffff;
    }
  </style>

  <script>
    // Password visibility toggles
    document.querySelectorAll<HTMLButtonElement>('.pwd-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const input = btn.closest('.input-wrapper')?.querySelector('input') as HTMLInputElement | null;
        const icon = btn.querySelector('.material-symbols-outlined');
        if (!input || !icon) return;
        if (input.type === 'password') {
          input.type = 'text';
          icon.textContent = 'visibility_off';
        } else {
          input.type = 'password';
          icon.textContent = 'visibility';
        }
      });
    });

    const form = document.getElementById('setup-form') as HTMLFormElement;
    const errorDiv = document.getElementById('error-message') as HTMLDivElement;
    const successDiv = document.getElementById('success-message') as HTMLDivElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!errorDiv || !successDiv) return;
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');
      errorDiv.textContent = '';
      successDiv.textContent = '';

      const formData = new FormData(form);
      const username = formData.get('username')?.toString().trim();
      const password = formData.get('password')?.toString();
      const confirmPassword = formData.get('confirmPassword')?.toString();

      if (!username || !password || !confirmPassword) {
        errorDiv.textContent = 'Please fill out all fields';
        errorDiv.classList.remove('hidden');
        return;
      }

      if (password !== confirmPassword) {
        errorDiv.textContent = 'Passwords do not match';
        errorDiv.classList.remove('hidden');
        return;
      }

      try {
        const res = await fetch('/api/auth/setup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password }),
        });

        const data = await res.json() as any;
        if (res.ok && data.ok) {
          successDiv.textContent = 'Administrator account created successfully! Redirecting...';
          successDiv.classList.remove('hidden');
          setTimeout(() => {
            window.location.href = '/login';
          }, 1500);
        } else {
          errorDiv.textContent = data.error || 'Setup failed';
          errorDiv.classList.remove('hidden');
        }
      } catch (err) {
        errorDiv.textContent = 'An unexpected connection error occurred';
        errorDiv.classList.remove('hidden');
      }
    });
  </script>
</body>
</html>
