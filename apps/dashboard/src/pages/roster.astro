---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getRosterStats, formatDate, derivePrepLevel } from '../lib/queries';

const env = Astro.locals.runtime?.env;
const hasDb = env?.TURSO_URL && env?.TURSO_TOKEN;

const stats = hasDb ? await getRosterStats(env) : [];

const totalSessions = stats.reduce((a, s) => a + Number(s.session_count), 0);
const withSessions  = stats.filter(s => Number(s.session_count) > 0);
const cohortAvg = withSessions.length
  ? Math.round(withSessions.reduce((a, s) => a + Number(s.avg_score), 0) / withSessions.length)
  : 0;

const total = stats.length || 1;
---

<DashboardLayout title="Roster" currentPath="/roster">

  <div class="page-header">
    <h1 class="page-title">Roster</h1>
    <p class="page-meta">
      {stats.length} students · {totalSessions} sessions · cohort avg {cohortAvg}% · {hasDb ? 'live data' : '⚠ no DB'}
    </p>
  </div>

  <div class="kpi-strip">
    {(['HIGH', 'MODERATE', 'LOW'] as const).map(lvl => {
      const count = stats.filter(s => s.best_prep_level === lvl).length;
      const pct   = Math.round((count / total) * 100);
      return (
        <div class="kpi-item">
          <span class="kpi-label">Best: {lvl}</span>
          <span class={`kpi-value tier-num-${lvl.toLowerCase()}`}>{count}</span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:#383838;">{pct}% of students</span>
        </div>
      );
    })}
    <div class="kpi-item">
      <span class="kpi-label">No sessions</span>
      <span class="kpi-value" style="color:#333;">{stats.filter(s => Number(s.session_count) === 0).length}</span>
      <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:#383838;">pending</span>
    </div>
  </div>

  <div class="dist-section">
    <div class="dist-head">
      <span class="section-label">Cohort distribution (best session)</span>
      <span class="dist-cohort">{stats.length} students</span>
    </div>
    <div class="dist-bar">
      {(['HIGH', 'MODERATE', 'LOW'] as const).map(lvl => {
        const count = stats.filter(s => s.best_prep_level === lvl).length;
        const pct   = Math.round((count / total) * 100);
        return <div class={`dist-seg ${lvl.toLowerCase()}`} style={`width: ${pct}%`}></div>;
      })}
    </div>
    <div class="dist-legend">
      {(['HIGH', 'MODERATE', 'LOW'] as const).map(lvl => {
        const count = stats.filter(s => s.best_prep_level === lvl).length;
        const pct   = Math.round((count / total) * 100);
        return (
          <div class="dist-leg-item">
            <span class={`leg-dot ${lvl.toLowerCase()}`}></span>
            <span class={`leg-tier ${lvl.toLowerCase()}`}>{lvl}</span>
            <span class="leg-count">{count} students · {pct}%</span>
          </div>
        );
      })}
    </div>
  </div>

  <div class="sessions-section">
    <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:16px;">
      <span class="section-label">Students</span>
    </div>

    {stats.length === 0 ? (
      <p style="font-family:'JetBrains Mono',monospace; font-size:12px; color:#555; padding:24px 0;">
        {hasDb ? 'No completed sessions yet.' : 'Configure TURSO_URL and TURSO_TOKEN to see live data.'}
      </p>
    ) : (
      <table class="sessions-table roster-table">
        <thead>
          <tr>
            <th>Student</th>
            <th>ID</th>
            <th>Section</th>
            <th>Sessions</th>
            <th>Avg score</th>
            <th>Best score</th>
            <th>Passed</th>
            <th>Best level</th>
            <th>Last active</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {stats.map(s => {
            const lvl = s.best_prep_level
              ? derivePrepLevel(Number(s.best_score), s.best_prep_level)
              : 'PENDING';
            return (
              <tr
                onclick={s.latest_session_id ? `window.location='/sessions/${s.latest_session_id}'` : undefined}
                style={s.latest_session_id ? 'cursor:pointer;' : ''}
              >
                <td class="name-cell">{s.student_name}</td>
                <td style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#555;">{s.student_id ?? '—'}</td>
                <td style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#555;">{s.section ?? '—'}</td>
                <td style="font-family:'JetBrains Mono',monospace; font-size:12px; color:#888;">{s.session_count}</td>
                <td>
                  {Number(s.session_count) > 0 ? (
                    <span style="font-family:'Space Grotesk',sans-serif; font-size:14px; font-weight:600; color:#888;">
                      {s.avg_score}
                    </span>
                  ) : (
                    <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#333;">—</span>
                  )}
                </td>
                <td style="font-family:'Space Grotesk',sans-serif; font-size:13px; font-weight:600; color:#666;">
                  {Number(s.session_count) > 0 ? s.best_score : '—'}
                </td>
                <td style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#888;">
                  {s.pass_count} / {s.session_count}
                </td>
                <td>
                  {lvl !== 'PENDING' ? (
                    <span class={`tier-badge ${lvl.toLowerCase()}`}>
                      <span class="dot"></span>
                      {lvl}
                    </span>
                  ) : (
                    <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#333;">—</span>
                  )}
                </td>
                <td style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#444;">
                  {s.latest_start ? formatDate(s.latest_start) : '—'}
                </td>
                <td class="link-cell">
                  {s.latest_session_id && (
                    <a href={`/sessions/${s.latest_session_id}`} class="view-link" onclick="event.stopPropagation()">→</a>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}

    <p class="roster-note">
      Clicking a row opens the student's most recent session. Best level is based on highest prep_level across all sessions.
    </p>
  </div>

</DashboardLayout>
