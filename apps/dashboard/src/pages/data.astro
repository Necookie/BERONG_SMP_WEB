---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Data Export" currentPath="/data">

  <div class="page-header">
    <h1 class="page-title">Data Export</h1>
    <p class="page-meta">Download telemetry datasets for ML training and analysis</p>
  </div>

  <!-- Synthetic Dataset -->
  <div class="data-section">
    <div class="data-section-header">
      <span class="data-section-label">Synthetic Dataset</span>
      <span class="data-badge">250 sessions · 301,288 rows</span>
    </div>
    <p class="data-desc">
      Machine-generated data matching telemetry contract v1.1 exactly. 250 sessions (150 FIRE + 100
      EARTHQUAKE) across 60 student profiles with individual personality traits — reaction time,
      panic tendency, procedure adherence, and movement speed — distributed across HIGH / MODERATE /
      LOW preparedness archetypes over 10 simulated data-collection days. Sessions CSV includes
      <code>prep_level</code>, <code>simulation_score</code>, and <code>passed</code> labels for direct supervised training.
    </p>
    <div class="data-note" style="margin-bottom: 14px;">
      <strong style="color: var(--text-primary);">Archetype breakdown:</strong>
      HIGH ≈38% (94) · MODERATE ≈44% (109) · LOW ≈19% (47) &nbsp;|&nbsp;
      Pass rate 50.0% · Avg score 52.8 &nbsp;|&nbsp;
      Each student appears in 2–8 sessions with consistent personality traits.
    </div>
    <div class="download-grid">
      <a href="/synthetic/gameplay_logs_synthetic_20260601.csv" download class="download-card">
        <div class="dl-icon">CSV</div>
        <div class="dl-info">
          <span class="dl-name">gameplay_logs_synthetic_20260601.csv</span>
          <span class="dl-meta">301,288 rows · 10 Hz move + events · ~20.1 MB</span>
        </div>
        <span class="dl-arrow">↓</span>
      </a>
      <a href="/synthetic/sessions_synthetic_20260601.csv" download class="download-card">
        <div class="dl-icon">CSV</div>
        <div class="dl-info">
          <span class="dl-name">sessions_synthetic_20260601.csv</span>
          <span class="dl-meta">250 rows · session metadata + labels · ~34 KB</span>
        </div>
        <span class="dl-arrow">↓</span>
      </a>
    </div>
    <div class="data-note">
      Columns match <code>RAW_LOG_SCHEMA</code> and <code>sessions</code> schema from the telemetry contract.
      Feed directly into <code>build_feature_table()</code> grouped by <code>player_id × scenario_type</code>.
      Labels (<code>prep_level</code>) are pre-attached for supervised training — no separate labeling step needed for synthetic data.
    </div>
  </div>

  <!-- Live Data Export -->
  <div class="data-section">
    <div class="data-section-header">
      <span class="data-section-label">Live Session Data</span>
      <span class="data-badge live">from Turso</span>
    </div>
    <p class="data-desc">
      Export all completed sessions from the live database. Includes student names, scores,
      scenario types, timestamps, and full event logs.
    </p>
    <div class="download-grid">
      <a href="/api/export/sessions" download="sessions_live.csv" class="download-card">
        <div class="dl-icon live">CSV</div>
        <div class="dl-info">
          <span class="dl-name">sessions_live.csv</span>
          <span class="dl-meta">All completed sessions · live query</span>
        </div>
        <span class="dl-arrow">↓</span>
      </a>
    </div>
    <div class="data-note">
      Gameplay log CSVs (move rows) are stored locally on the Minecraft server under
      <code>run/telemetry/gameplay_logs_&lt;date&gt;.csv</code> — retrieve them directly from that machine.
    </div>
  </div>

</DashboardLayout>

<style>
  .data-section {
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 6px;
    padding: 20px 24px;
    margin-bottom: 16px;
  }

  .data-section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .data-section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-primary);
  }

  .data-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    padding: 2px 7px;
    border-radius: 3px;
    background: var(--bg-filter-pill-active);
    color: var(--text-brand);
    border: 1px solid var(--text-brand);
  }

  .data-badge.live {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    border-color: rgba(59, 130, 246, 0.3);
  }
  
  html.dark .data-badge.live {
    background: rgba(130, 170, 255, 0.08);
    color: #82aaff;
    border-color: rgba(130, 170, 255, 0.3);
  }

  .data-desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .download-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
    margin-bottom: 12px;
  }

  .download-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    border: 1px solid var(--border-card);
    border-radius: 5px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
    background: var(--bg-base);
  }

  .download-card:hover {
    border-color: var(--text-brand);
    background: var(--bg-table-hover);
  }

  .dl-icon {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 6px;
    border-radius: 3px;
    background: rgba(201, 168, 76, 0.1);
    color: #c9a84c;
    border: 1px solid rgba(201, 168, 76, 0.3);
    flex-shrink: 0;
  }

  .dl-icon.live {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    border-color: rgba(59, 130, 246, 0.3);
  }

  html.dark .dl-icon.live {
    background: rgba(130, 170, 255, 0.08);
    color: #82aaff;
    border-color: rgba(130, 170, 255, 0.3);
  }

  .dl-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .dl-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dl-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dl-arrow {
    font-size: 16px;
    color: var(--text-secondary);
  }

  .data-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    line-height: 1.5;
    padding: 8px 12px;
    border-left: 2px solid var(--border-card);
  }

  .data-note code {
    color: var(--text-secondary);
  }
</style>
