---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { EventLog } from '../../components/EventLog.tsx';
import { MapPlayer } from '../../components/MapPlayer.tsx';
import { getSessionById, getAuditLog, formatDuration, formatDate, derivePrepLevel, parseEventLog, extractRubricSignals } from '../../lib/queries';
import { getEnv } from '../../lib/db';

const { id } = Astro.params;
const env = await getEnv();

const session = (env && id) ? await getSessionById(env, Number(id)) : null;

if (!session) {
  return new Response(null, { status: 404, statusText: 'Session not found' });
}

const level = derivePrepLevel(session.simulation_score, session.prep_level);
const tierClass = level !== 'PENDING' ? level.toLowerCase() : 'low';
const isFireSession = session.simulation_type === 'FIRE' || session.simulation_type === 'CCS_FIRE';
const logEntries = parseEventLog(session.event_log);
const rubric     = extractRubricSignals(session.event_log);
const auditLogs = env ? await getAuditLog(env, Number(id)) : [];
---

<DashboardLayout
  title={`Session ${session.id}`}
  currentPath="/sessions"
  fullscreen={true}
>

  <div class={`session-header-bar ${tierClass}`}>
    <div style="display: flex; align-items: center; gap: 16px; flex-grow: 1; flex-wrap: wrap;">
      <a href="/sessions" class="back-link">← Sessions</a>
      <span class="header-sep">|</span>
      <span class="session-id-tag">#{session.id}</span>
      <span class="header-sep">|</span>
      <span class="session-participant-name">{session.student_name}</span>
      {session.student_id && (
        <>
          <span class="header-sep">·</span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text-muted);">{session.student_id}</span>
        </>
      )}
      <span class="header-sep">·</span>
      <span class="scenario-tag">{session.simulation_type ?? '—'}</span>
      {level !== 'PENDING' && (
        <span class={`tier-badge ${tierClass}`} style="margin-left: 4px;">
          <span class="dot"></span>
          {level}
        </span>
      )}
      <span class="header-date">{formatDate(session.start_time)}</span>
    </div>
    <div style="display: flex; gap: 8px; align-items: center; margin-left: 16px; flex-shrink: 0;">
      {session.move_log_csv && (
        <a href={`/api/sessions/${session.id}/move-log`}
           class="btn-cancel"
           style="margin-top:0; padding:5px 12px; font-weight:500; text-decoration:none; display:inline-block;">
          ↓ Move Log CSV
        </a>
      )}
      <button id="btn-edit-details" class="btn-cancel" style="margin-top: 0; padding: 5px 12px; font-weight: 500;">Edit Details</button>
      <button id="btn-delete-session" class="delete-btn" style="padding: 5px 12px; font-weight: 500;">Delete</button>
    </div>
  </div>

  <div class="detail-split">

    <div class="log-panel">
      <!-- Tab bar -->
      <div style="display:flex; border-bottom:1px solid var(--border-card); background:var(--bg-sidebar);">
        <button id="tab-log" class="log-tab active" data-tab="log">
          Event Log
          <span style="margin-left:6px; font-size:9px; color:var(--text-muted);">{logEntries.length}</span>
        </button>
        {session.move_log_csv && (
          <button id="tab-map" class="log-tab" data-tab="map">
            Movement Map
            <span style="margin-left:6px; font-size:9px; color:var(--text-muted);">10 Hz</span>
          </button>
        )}
      </div>

      <!-- Event log pane -->
      <div id="pane-log" class="event-log-wrap">
        {logEntries.length > 0 ? (
          <EventLog client:only="react" entries={logEntries} />
        ) : (
          <div class="event-log" style="padding:16px;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text-muted);">
              No event log data for this session.
            </span>
          </div>
        )}
      </div>

      <!-- Movement map pane (hidden by default) -->
      {session.move_log_csv && (
        <div id="pane-map" style="display:none; height:100%; overflow:auto;">
          <MapPlayer
            client:only="react"
            moveCsv={session.move_log_csv}
            simulationType={session.simulation_type}
          />
        </div>
      )}
    </div>

    <div class="stats-panel">
      <div class="stats-inner">

        <div class="stat-section">
          <span class="stat-section-label">Session statistics</span>
          <div class="stat-grid">
            <span class="stat-key">Scenario</span>
            <span class="stat-val hi">{session.simulation_type ?? '—'}</span>

            <span class="stat-key">Duration</span>
            <span class="stat-val hi">{formatDuration(session.start_time, session.end_time)}</span>

            <span class="stat-key">Score</span>
            <span class="stat-val hi">{session.simulation_score} / 100</span>

            <span class="stat-key">Participant</span>
            <span class="stat-val">{session.student_name}</span>

            {session.student_id && (
              <>
                <span class="stat-key">Student ID</span>
                <span class="stat-val">{session.student_id}</span>
              </>
            )}

            <span class="stat-key">Section</span>
            <span class="stat-val">{session.section ?? '—'}</span>

            <span class="stat-key">Date</span>
            <span class="stat-val">{formatDate(session.start_time)}</span>

            <span class="stat-key">Tutorial</span>
            <span class="stat-val">
              {session.tutorial_completed
                ? `done · ${session.tutorial_duration_s != null ? session.tutorial_duration_s + 's' : '?'}`
                : 'skipped'}
            </span>
          </div>
        </div>

        <div class="stat-section">
          <span class="stat-section-label">Rubric signals</span>
          <div class="stat-grid" style="margin-top:8px;">

            {isFireSession && (
              <>
                <span class="stat-key">Fire alarm</span>
                <span class="stat-val" style={`color: ${rubric.alarmActivated ? 'var(--color-fire)' : 'var(--text-muted)'}`}>
                  {rubric.alarmActivated ? '✓ Activated' : '— Not installed'}
                </span>

                <span class="stat-key">Extinguisher hits</span>
                <span class="stat-val">{rubric.extHits > 0 ? rubric.extHits : '—'}</span>
              </>
            )}

            <span class="stat-key">Doors opened</span>
            <span class="stat-val">{rubric.doorOpens > 0 ? rubric.doorOpens : '—'}</span>

            <span class="stat-key">Exit used</span>
            <span class="stat-val">
              {rubric.exitUsed
                ? <span style="font-family:'JetBrains Mono',monospace; font-size:10px;">{rubric.exitUsed}</span>
                : <span style="color:var(--text-muted);">—</span>}
            </span>

            <span class="stat-key">Assembly area</span>
            <span class="stat-val" style={`color: ${rubric.assemblyReached ? 'var(--color-fire)' : '#c45c5c'}`}>
              {rubric.assemblyReached ? '✓ Reached' : '✗ Not reached'}
            </span>

            <span class="stat-key">Evacuation time</span>
            <span class="stat-val">
              {rubric.evacuationTimeSec != null
                ? `${rubric.evacuationTimeSec.toFixed(1)}s`
                : <span style="color:var(--text-muted);">—</span>}
            </span>

          </div>

          {session.prep_level && (
            <div class="feat-list" style="margin-top:12px;">
              <div class="feat-row">
                <div class="feat-header">
                  <span class="feat-name">RF Confidence</span>
                  <span class="feat-score">{Math.round((session.confidence ?? 0) * 100)}%</span>
                </div>
                <div class="feat-track">
                  <div class="feat-fill" style={`width: ${Math.round((session.confidence ?? 0) * 100)}%`}></div>
                </div>
              </div>
              <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--text-muted); margin-top:6px;">
                Prep level assigned by Random Forest classifier.
              </p>
            </div>
          )}
        </div>

        <div class="stat-section">
          <div class={`result-block ${tierClass}`}>
            <div class="result-top">
              <span class="result-tier">{level}</span>
              <span class="result-score">
                {session.simulation_score}<span class="result-score-unit"> / 100</span>
              </span>
            </div>
            <span class="result-sublabel">Preparedness level</span>
            {session.passed === 1 ? (
              <p class="result-text">Passed the drill threshold.</p>
            ) : (
              <p class="result-text">Did not meet the passing threshold.</p>
            )}
            {level === 'LOW' && (
              <div class="retake-flag">⚑ RETAKE REQUIRED</div>
            )}
            {session.bfp_notes && (
              <div style="margin-top:10px; padding:8px; background:var(--bg-notes-block); border-radius:4px;">
                <span style="font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--text-notes-label); display:block; margin-bottom:4px;">BFP NOTES</span>
                <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--text-notes-body); line-height:1.5; margin:0;">{session.bfp_notes}</p>
              </div>
            )}
          </div>
        </div>

        <div class="stat-section">
          <span class="stat-section-label">BFP Officer Notes</span>
          <form method="POST" action={`/api/sessions/${session.id}/notes`} style="margin-top:8px;">
            <textarea
              name="notes"
              placeholder="Validation notes, observations, remarks..."
              class="notes-input"
            >{session.bfp_notes ?? ''}</textarea>
            <button type="submit" class="notes-save-btn">Save Notes</button>
          </form>
        </div>

        {auditLogs.length > 0 && (
          <div class="stat-section">
            <span class="stat-section-label">Change History</span>
            <div class="audit-log-list" style="margin-top: 8px; display: flex; flex-direction: column; gap: 8px;">
              {auditLogs.map(log => {
                const oldVals = log.old_values ? JSON.parse(log.old_values) : null;
                const newVals = log.new_values ? JSON.parse(log.new_values) : null;
                
                const changes: string[] = [];
                if (log.action === 'edit' && oldVals && newVals) {
                  const keys = Object.keys(newVals);
                  for (const key of keys) {
                    if (oldVals[key] !== newVals[key]) {
                      const displayKey = key.replace('_', ' ');
                      changes.push(`${displayKey}: "${oldVals[key] ?? '—'}" → "${newVals[key] ?? '—'}"`);
                    }
                  }
                }

                return (
                  <div style="font-family:'JetBrains Mono',monospace; font-size:10px; padding:8px; border:1px solid var(--border-card); border-radius:4px; background:var(--bg-base); box-sizing:border-box;">
                    <div style="display:flex; justify-content:space-between; margin-bottom:4px; color:var(--text-muted); flex-wrap:wrap;">
                      <span>{log.action.toUpperCase()} by {log.changed_by}</span>
                      <span>{new Date(log.changed_at).toLocaleString('en-PH', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false, month: 'short', day: 'numeric' })}</span>
                    </div>
                    {changes.length > 0 ? (
                      <ul style="margin:0; padding-left:14px; color:var(--text-primary); list-style-type:disc;">
                        {changes.map(ch => <li>{ch}</li>)}
                      </ul>
                    ) : (
                      <span style="color:var(--text-primary);">{log.action === 'delete' ? 'Session deleted' : 'No fields changed'}</span>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        )}

      </div>
    </div>

  </div>

  <!-- Edit Details Modal -->
  <div id="modal-edit" class="modal-overlay">
    <div class="modal-container">
      <div class="modal-header">
        <h3 class="modal-title">Edit Session Details</h3>
        <button id="edit-close" class="modal-close" type="button">✕</button>
      </div>
      <form method="POST" action={`/api/sessions/${session.id}/edit`}>
        <div class="modal-body">
          <div class="form-grid">
            <div class="form-group full-width">
              <label class="form-label" for="student_name">Student Name</label>
              <input type="text" id="student_name" name="student_name" value={session.student_name} class="form-input" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="student_id">Student ID</label>
              <input type="text" id="student_id" name="student_id" value={session.student_id ?? ''} placeholder="e.g. 2026-0001" class="form-input" />
            </div>
            <div class="form-group">
              <label class="form-label" for="section">Section</label>
              <input type="text" id="section" name="section" value={session.section ?? ''} placeholder="e.g. G12-A" class="form-input" />
            </div>
            <div class="form-group">
              <label class="form-label" for="simulation_type">Scenario</label>
              <select id="simulation_type" name="simulation_type" class="form-select">
                <option value="FIRE" selected={session.simulation_type === 'FIRE'}>FIRE</option>
                <option value="EARTHQUAKE" selected={session.simulation_type === 'EARTHQUAKE'}>EARTHQUAKE</option>
                <option value="CCS_FIRE" selected={session.simulation_type === 'CCS_FIRE'}>CCS_FIRE</option>
                <option value="CCS_EARTHQUAKE" selected={session.simulation_type === 'CCS_EARTHQUAKE'}>CCS_EARTHQUAKE</option>
                <option value="" selected={session.simulation_type === null}>None</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="simulation_score">Score (0-100)</label>
              <input type="number" id="simulation_score" name="simulation_score" min="0" max="100" value={session.simulation_score} class="form-input" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="prep_level">Prep Level</label>
              <select id="prep_level" name="prep_level" class="form-select">
                <option value="HIGH" selected={session.prep_level === 'HIGH'}>HIGH</option>
                <option value="MODERATE" selected={session.prep_level === 'MODERATE'}>MODERATE</option>
                <option value="LOW" selected={session.prep_level === 'LOW'}>LOW</option>
                <option value="PENDING" selected={session.prep_level === null || session.prep_level === 'PENDING'}>PENDING</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="passed">Status</label>
              <select id="passed" name="passed" class="form-select">
                <option value="1" selected={session.passed === 1}>Passed</option>
                <option value="0" selected={session.passed === 0}>Failed</option>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button id="edit-cancel" type="button" class="btn-cancel">Cancel</button>
          <button type="submit" class="btn-save">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="modal-delete" class="modal-overlay">
    <div class="modal-container" style="max-width: 400px;">
      <div class="modal-header">
        <h3 class="modal-title" style="color: var(--text-danger);">Delete Session Log</h3>
        <button id="delete-close" class="modal-close" type="button">✕</button>
      </div>
      <form method="POST" action={`/api/sessions/${session.id}/delete`}>
        <div class="modal-body">
          <p style="font-size: 13px; line-height: 1.6; margin: 0; color: var(--text-primary);">
            Are you sure you want to permanently delete this drill session log for <strong>{session.student_name}</strong>?
          </p>
          <p style="font-size: 11px; line-height: 1.5; margin: 8px 0 0; color: var(--text-danger); font-family: 'JetBrains Mono', monospace;">
            Warning: This action is permanent, deletes the record from the database, and cannot be undone.
          </p>
        </div>
        <div class="modal-footer">
          <button id="delete-cancel" type="button" class="btn-cancel">Cancel</button>
          <button type="submit" class="btn-delete-confirm">Delete Permanently</button>
        </div>
      </form>
    </div>
  </div>

</DashboardLayout>

<style>
  .log-tab {
    padding: 8px 16px;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .log-tab:hover { color: var(--text-primary); }
  .log-tab.active {
    color: var(--text-primary);
    border-bottom-color: var(--text-brand);
  }
</style>

<script>
  // Tab switching
  const paneLog = document.getElementById('pane-log');
  const paneMap = document.getElementById('pane-map');
  const tabLog  = document.getElementById('tab-log');
  const tabMap  = document.getElementById('tab-map');

  function switchTab(tab: string) {
    const isLog = tab === 'log';
    if (paneLog) paneLog.style.display = isLog ? '' : 'none';
    if (paneMap) paneMap.style.display = isLog ? 'none' : '';
    tabLog?.classList.toggle('active', isLog);
    tabMap?.classList.toggle('active', !isLog);
  }

  tabLog?.addEventListener('click', () => switchTab('log'));
  tabMap?.addEventListener('click', () => switchTab('map'));

  const btnEdit = document.getElementById('btn-edit-details');
  const btnDelete = document.getElementById('btn-delete-session');
  
  const modalEdit = document.getElementById('modal-edit');
  const modalDelete = document.getElementById('modal-delete');
  
  const editClose = document.getElementById('edit-close');
  const editCancel = document.getElementById('edit-cancel');
  
  const deleteClose = document.getElementById('delete-close');
  const deleteCancel = document.getElementById('delete-cancel');
  
  if (btnEdit && modalEdit) {
    btnEdit.addEventListener('click', () => {
      modalEdit.classList.add('open');
    });
  }
  
  if (btnDelete && modalDelete) {
    btnDelete.addEventListener('click', () => {
      modalDelete.classList.add('open');
    });
  }
  
  // Close handlers
  const closeEdit = () => modalEdit?.classList.remove('open');
  editClose?.addEventListener('click', closeEdit);
  editCancel?.addEventListener('click', closeEdit);
  
  const closeDelete = () => modalDelete?.classList.remove('open');
  deleteClose?.addEventListener('click', closeDelete);
  deleteCancel?.addEventListener('click', closeDelete);
  
  // Close on clicking overlay
  window.addEventListener('click', (e) => {
    if (e.target === modalEdit) closeEdit();
    if (e.target === modalDelete) closeDelete();
  });
</script>
