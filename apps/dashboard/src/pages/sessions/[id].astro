---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { EventLog } from '../../components/EventLog.tsx';
import { getSessionById, formatDuration, formatDate, derivePrepLevel, parseEventLog, extractRubricSignals } from '../../lib/queries';
import { getEnv } from '../../lib/db';

const { id } = Astro.params;
const env = await getEnv();

const session = (env && id) ? await getSessionById(env, Number(id)) : null;

if (!session) {
  return new Response(null, { status: 404, statusText: 'Session not found' });
}

const level = derivePrepLevel(session.simulation_score, session.prep_level);
const tierClass = level !== 'PENDING' ? level.toLowerCase() : 'low';
const isFireSession = session.simulation_type === 'FIRE';
const logEntries = parseEventLog(session.event_log);
const rubric     = extractRubricSignals(session.event_log);
---

<DashboardLayout
  title={`Session ${session.id}`}
  currentPath="/sessions"
  fullscreen={true}
>

  <div class={`session-header-bar ${tierClass}`}>
    <a href="/sessions" class="back-link">← Sessions</a>
    <span class="header-sep">|</span>
    <span class="session-id-tag">#{session.id}</span>
    <span class="header-sep">|</span>
    <span class="session-participant-name">{session.student_name}</span>
    {session.student_id && (
      <>
        <span class="header-sep">·</span>
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#555;">{session.student_id}</span>
      </>
    )}
    <span class="header-sep">·</span>
    <span class="scenario-tag">{session.simulation_type ?? '—'}</span>
    {level !== 'PENDING' && (
      <span class={`tier-badge ${tierClass}`} style="margin-left: 4px;">
        <span class="dot"></span>
        {level}
      </span>
    )}
    <span class="header-date">{formatDate(session.start_time)}</span>
  </div>

  <div class="detail-split">

    <div class="log-panel">
      <div class="panel-header">
        <span class="section-label">Event log</span>
        <span style="float:right; font-family:'JetBrains Mono',monospace; font-size:10px; color:#333;">
          {logEntries.length} events
        </span>
      </div>
      <div class="event-log-wrap">
        {logEntries.length > 0 ? (
          <EventLog client:only="react" entries={logEntries} />
        ) : (
          <div class="event-log" style="padding:16px;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#333;">
              No event log data for this session.
            </span>
          </div>
        )}
      </div>
    </div>

    <div class="stats-panel">
      <div class="stats-inner">

        <div class="stat-section">
          <span class="stat-section-label">Session statistics</span>
          <div class="stat-grid">
            <span class="stat-key">Scenario</span>
            <span class="stat-val hi">{session.simulation_type ?? '—'}</span>

            <span class="stat-key">Duration</span>
            <span class="stat-val hi">{formatDuration(session.start_time, session.end_time)}</span>

            <span class="stat-key">Score</span>
            <span class="stat-val hi">{session.simulation_score} / 100</span>

            <span class="stat-key">Participant</span>
            <span class="stat-val">{session.student_name}</span>

            {session.student_id && (
              <>
                <span class="stat-key">Student ID</span>
                <span class="stat-val">{session.student_id}</span>
              </>
            )}

            <span class="stat-key">Section</span>
            <span class="stat-val">{session.section ?? '—'}</span>

            <span class="stat-key">Date</span>
            <span class="stat-val">{formatDate(session.start_time)}</span>

            <span class="stat-key">Tutorial</span>
            <span class="stat-val">
              {session.tutorial_completed
                ? `done · ${session.tutorial_duration_s != null ? session.tutorial_duration_s + 's' : '?'}`
                : 'skipped'}
            </span>
          </div>
        </div>

        <div class="stat-section">
          <span class="stat-section-label">Rubric signals</span>
          <div class="stat-grid" style="margin-top:8px;">

            {isFireSession && (
              <>
                <span class="stat-key">Fire alarm</span>
                <span class="stat-val" style={`color: ${rubric.alarmActivated ? '#88d982' : '#555'}`}>
                  {rubric.alarmActivated ? '✓ Activated' : '— Not installed'}
                </span>

                <span class="stat-key">Extinguisher hits</span>
                <span class="stat-val">{rubric.extHits > 0 ? rubric.extHits : '—'}</span>
              </>
            )}

            <span class="stat-key">Doors opened</span>
            <span class="stat-val">{rubric.doorOpens > 0 ? rubric.doorOpens : '—'}</span>

            <span class="stat-key">Exit used</span>
            <span class="stat-val">
              {rubric.exitUsed
                ? <span style="font-family:'JetBrains Mono',monospace; font-size:10px;">{rubric.exitUsed}</span>
                : <span style="color:#555;">—</span>}
            </span>

            <span class="stat-key">Assembly area</span>
            <span class="stat-val" style={`color: ${rubric.assemblyReached ? '#88d982' : '#c45c5c'}`}>
              {rubric.assemblyReached ? '✓ Reached' : '✗ Not reached'}
            </span>

            <span class="stat-key">Evacuation time</span>
            <span class="stat-val">
              {rubric.evacuationTimeSec != null
                ? `${rubric.evacuationTimeSec.toFixed(1)}s`
                : <span style="color:#555;">—</span>}
            </span>

          </div>

          {session.prep_level && (
            <div class="feat-list" style="margin-top:12px;">
              <div class="feat-row">
                <div class="feat-header">
                  <span class="feat-name">RF Confidence</span>
                  <span class="feat-score">{Math.round((session.confidence ?? 0) * 100)}%</span>
                </div>
                <div class="feat-track">
                  <div class="feat-fill" style={`width: ${Math.round((session.confidence ?? 0) * 100)}%`}></div>
                </div>
              </div>
              <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:#444; margin-top:6px;">
                Prep level assigned by Random Forest classifier.
              </p>
            </div>
          )}
        </div>

        <div class="stat-section">
          <div class={`result-block ${tierClass}`}>
            <div class="result-top">
              <span class="result-tier">{level}</span>
              <span class="result-score">
                {session.simulation_score}<span class="result-score-unit"> / 100</span>
              </span>
            </div>
            <span class="result-sublabel">Preparedness level</span>
            {session.passed === 1 ? (
              <p class="result-text">Passed the drill threshold.</p>
            ) : (
              <p class="result-text">Did not meet the passing threshold.</p>
            )}
            {level === 'LOW' && (
              <div class="retake-flag">⚑ RETAKE REQUIRED</div>
            )}
            {session.bfp_notes && (
              <div style="margin-top:10px; padding:8px; background:#1a1a1a; border-radius:4px;">
                <span style="font-family:'JetBrains Mono',monospace; font-size:9px; color:#555; display:block; margin-bottom:4px;">BFP NOTES</span>
                <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:#888; line-height:1.5; margin:0;">{session.bfp_notes}</p>
              </div>
            )}
          </div>
        </div>

        <div class="stat-section">
          <span class="stat-section-label">BFP Officer Notes</span>
          <form method="POST" action={`/api/sessions/${session.id}/notes`} style="margin-top:8px;">
            <textarea
              name="notes"
              placeholder="Validation notes, observations, remarks..."
              class="notes-input"
            >{session.bfp_notes ?? ''}</textarea>
            <button type="submit" class="notes-save-btn">Save Notes</button>
          </form>
        </div>

      </div>
    </div>

  </div>

</DashboardLayout>
