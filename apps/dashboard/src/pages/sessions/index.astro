---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ErrorCard from '../../components/ErrorCard.astro';
import { getAllSessions, getSessionCount, formatDuration, formatDate, derivePrepLevel } from '../../lib/queries';
import { getEnv } from '../../lib/db';

const env = await getEnv();
const hasDb = !!env;

const pageParam = Astro.url.searchParams.get('page');
let page = pageParam ? parseInt(pageParam, 10) : 1;
if (isNaN(page) || page < 1) page = 1;

const limit = 25;
const offset = (page - 1) * limit;

let sessions: Awaited<ReturnType<typeof getAllSessions>> = [];
let totalSessions = 0;
let dbError: string | null = null;

if (env) {
  try {
    totalSessions = await getSessionCount(env);
    sessions = await getAllSessions(env, limit, offset);
  } catch (err) {
    dbError = err instanceof Error ? err.message : 'Unknown database error';
  }
}

const totalPages = Math.max(1, Math.ceil(totalSessions / limit));
---

<DashboardLayout title="Sessions" currentPath="/sessions">

  <div class="page-header">
    <h1 class="page-title">Sessions</h1>
    <p class="page-meta">All drill sessions · {totalSessions} records · {hasDb ? (dbError ? '⚠ DB error' : 'live data') : '⚠ no DB'}</p>
  </div>

  {dbError && <ErrorCard message={dbError} />}

  <div class="filter-bar">
    <div class="filter-group">
      <span class="filter-label">Scenario</span>
      <div class="filter-pills" id="filter-type">
        <button class="filter-pill active" data-value="ALL">All</button>
        <button class="filter-pill" data-value="FIRE">Fire</button>
        <button class="filter-pill" data-value="EARTHQUAKE">Earthquake</button>
      </div>
    </div>
    <div class="filter-group">
      <span class="filter-label">Level</span>
      <div class="filter-pills" id="filter-level">
        <button class="filter-pill active" data-value="ALL">All</button>
        <button class="filter-pill" data-value="HIGH">High</button>
        <button class="filter-pill" data-value="MODERATE">Moderate</button>
        <button class="filter-pill" data-value="LOW">Low</button>
      </div>
    </div>
    <div class="filter-group" style="margin-left: auto;">
      <div class="search-wrapper">
        <span class="search-icon">🔍</span>
        <input type="text" id="search-input" placeholder="Search student, ID, section..." class="search-input" />
      </div>
    </div>
    <span class="filter-count" id="session-count">{sessions.length} sessions</span>
  </div>

  <div class="sessions-section">
    {sessions.length === 0 ? (
      <p class="td-no-data" style="padding:24px 0; text-align:center;">
        {hasDb ? 'No sessions yet.' : 'Configure TURSO_URL and TURSO_TOKEN to see live data.'}
      </p>
    ) : (
      <>
        <div id="bulk-toolbar" class="bulk-toolbar" style="display:none;">
          <span class="bulk-toolbar-info"><span id="bulk-select-count">0</span> sessions selected</span>
          <button id="btn-bulk-delete" class="btn-bulk-delete">Delete Selected</button>
        </div>

        <div class="table-scroll-wrap">
          <table class="sessions-table" id="sessions-table">
            <thead>
              <tr>
                <th class="checkbox-col"><input type="checkbox" id="check-all" /></th>
                <th class="sortable" data-sort-key="id">ID</th>
                <th class="sortable" data-sort-key="student">Student</th>
                <th class="sortable" data-sort-key="section">Section</th>
                <th class="sortable" data-sort-key="scenario">Scenario</th>
                <th class="sortable" data-sort-key="date">Date</th>
                <th class="sortable" data-sort-key="duration">Duration</th>
                <th class="sortable" data-sort-key="score">Score</th>
                <th class="sortable" data-sort-key="level">Level</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {sessions.map(s => {
                const level = derivePrepLevel(s.simulation_score, s.prep_level);
                const durationMs = s.start_time && s.end_time 
                  ? new Date(s.end_time).getTime() - new Date(s.start_time).getTime() 
                  : 0;
                return (
                  <tr
                    data-type={s.simulation_type ?? 'UNKNOWN'}
                    data-level={level}
                    data-search={`${s.student_name} ${s.student_id ?? ''} ${s.section ?? ''}`.toLowerCase()}
                    data-sort-id={s.id}
                    data-sort-student={s.student_name.toLowerCase()}
                    data-sort-section={(s.section ?? '').toLowerCase()}
                    data-sort-scenario={(s.simulation_type ?? 'UNKNOWN').toLowerCase()}
                    data-sort-date={s.start_time ? new Date(s.start_time).getTime() : 0}
                    data-sort-duration={durationMs}
                    data-sort-score={s.simulation_score}
                    data-sort-level={level === 'HIGH' ? 3 : level === 'MODERATE' ? 2 : level === 'LOW' ? 1 : 0}
                    onclick={`window.location='/sessions/${s.id}'`}
                  >
                    <td class="checkbox-col" onclick="event.stopPropagation()">
                      <input type="checkbox" class="row-check" data-id={s.id} />
                    </td>
                    <td class="td-mono-id">
                      {s.id}
                    </td>
                    <td class="name-cell">{s.student_name}</td>
                    <td class="td-mono-muted">{s.section ?? '—'}</td>
                    <td>
                      <span class={s.simulation_type === 'FIRE' ? 'td-type-fire' : 'td-type-quake'}>
                        {s.simulation_type ?? '—'}
                      </span>
                    </td>
                    <td class="td-mono-muted">{formatDate(s.start_time)}</td>
                    <td class="td-mono-muted">{formatDuration(s.start_time, s.end_time)}</td>
                    <td class="td-score">
                      {s.simulation_score}
                    </td>
                    <td>
                      {level !== 'PENDING' ? (
                        <span class={`tier-badge ${level.toLowerCase()}`}>
                          <span class="dot"></span>
                          {level}
                        </span>
                      ) : (
                        <span class="td-pending">PENDING</span>
                      )}
                    </td>
                    <td class="link-cell">
                      <a href={`/sessions/${s.id}`} class="view-link" onclick="event.stopPropagation()">→</a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        {totalPages > 1 && (
          <div class="pagination">
            <a
              href={page > 1 ? `?page=${page - 1}` : '#'}
              class={`pagination-btn ${page <= 1 ? 'disabled' : ''}`}
              aria-disabled={page <= 1}
            >
              &larr; Prev
            </a>
            <span class="pagination-info">
              Page <strong>{page}</strong> of <strong>{totalPages}</strong>
            </span>
            <a
              href={page < totalPages ? `?page=${page + 1}` : '#'}
              class={`pagination-btn ${page >= totalPages ? 'disabled' : ''}`}
              aria-disabled={page >= totalPages}
            >
              Next &rarr;
            </a>
          </div>
        )}

        <div id="empty-state" class="sessions-empty" style="display:none;">
          <span class="sessions-empty-text">No sessions match the selected filters.</span>
        </div>
      </>
    )}
  </div>

</DashboardLayout>

<script>
  import { initTableSorting } from '../../lib/tableSorter';

  // Initialize sorting
  initTableSorting();

  const typeGroup   = document.getElementById('filter-type');
  const levelGroup  = document.getElementById('filter-level');
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const table       = document.getElementById('sessions-table');
  const countLabel  = document.getElementById('session-count');
  const emptyState  = document.getElementById('empty-state');

  // Bulk Actions
  const checkAll = document.getElementById('check-all') as HTMLInputElement | null;
  const rowChecks = document.querySelectorAll('.row-check');
  const bulkToolbar = document.getElementById('bulk-toolbar');
  const bulkSelectCount = document.getElementById('bulk-select-count');
  const btnBulkDelete = document.getElementById('btn-bulk-delete');

  function updateBulkToolbar() {
    const checkedRows = document.querySelectorAll('.row-check:checked');
    const count = checkedRows.length;
    if (bulkToolbar && bulkSelectCount) {
      if (count > 0) {
        bulkToolbar.style.display = 'flex';
        bulkSelectCount.textContent = count.toString();
      } else {
        bulkToolbar.style.display = 'none';
      }
    }
    if (checkAll) {
      const allChecked = rowChecks.length > 0 && Array.from(rowChecks).every(c => (c as HTMLInputElement).checked);
      const someChecked = count > 0 && count < rowChecks.length;
      checkAll.checked = allChecked;
      checkAll.indeterminate = someChecked;
    }
  }

  if (checkAll) {
    checkAll.addEventListener('change', () => {
      const rows = table!.querySelectorAll<HTMLTableRowElement>('tbody tr');
      rows.forEach(row => {
        if (row.style.display !== 'none') {
          const check = row.querySelector('.row-check') as HTMLInputElement | null;
          if (check) {
            check.checked = checkAll.checked;
          }
        }
      });
      updateBulkToolbar();
    });
  }

  rowChecks.forEach(check => {
    check.addEventListener('change', updateBulkToolbar);
  });

  if (btnBulkDelete) {
    btnBulkDelete.addEventListener('click', async () => {
      const checkedRows = document.querySelectorAll('.row-check:checked');
      const ids = Array.from(checkedRows).map(c => Number((c as HTMLInputElement).dataset.id));
      if (ids.length === 0) return;

      const confirmMsg = `Are you sure you want to delete the selected ${ids.length} session(s)? This action cannot be undone.`;
      if (!confirm(confirmMsg)) return;

      try {
        btnBulkDelete.setAttribute('disabled', 'true');
        btnBulkDelete.textContent = 'Deleting...';

        const res = await fetch('/api/sessions/bulk-delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids }),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const errData = await res.json() as { error?: string };
          alert(`Failed to delete sessions: ${errData.error || 'Unknown error'}`);
          btnBulkDelete.removeAttribute('disabled');
          btnBulkDelete.textContent = 'Delete Selected';
        }
      } catch (err) {
        console.error(err);
        alert('An error occurred while deleting sessions.');
        btnBulkDelete.removeAttribute('disabled');
        btnBulkDelete.textContent = 'Delete Selected';
      }
    });
  }

  if (typeGroup && levelGroup && table && countLabel && emptyState) {
    let activeType  = 'ALL';
    let activeLevel = 'ALL';

    function applyFilters() {
      const rows = table!.querySelectorAll<HTMLTableRowElement>('tbody tr');
      const query = searchInput ? searchInput.value.toLowerCase().trim() : '';
      let visible = 0;
      rows.forEach(row => {
        const typeMatch  = activeType  === 'ALL' || row.dataset.type  === activeType;
        const levelMatch = activeLevel === 'ALL' || row.dataset.level === activeLevel;
        const searchMatch = !query || (row.dataset.search && row.dataset.search.includes(query));
        const show = typeMatch && levelMatch && searchMatch;
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      countLabel!.textContent = `${visible} session${visible !== 1 ? 's' : ''}`;
      emptyState!.style.display = visible === 0 ? '' : 'none';
      table!.style.display = visible === 0 ? 'none' : '';

      // Uncheck non-visible checkboxes on filter change
      rows.forEach(row => {
        if (row.style.display === 'none') {
          const check = row.querySelector('.row-check') as HTMLInputElement | null;
          if (check) check.checked = false;
        }
      });
      updateBulkToolbar();
    }

    function bindPills(group: HTMLElement, onChange: (v: string) => void) {
      group.querySelectorAll<HTMLButtonElement>('.filter-pill').forEach(pill => {
        pill.addEventListener('click', () => {
          group.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
          pill.classList.add('active');
          onChange(pill.dataset.value!);
          applyFilters();
        });
      });
    }

    bindPills(typeGroup,  v => { activeType  = v; });
    bindPills(levelGroup, v => { activeLevel = v; });
    
    if (searchInput) {
      searchInput.addEventListener('input', applyFilters);
    }
  }
</script>
