---
// Footer.astro – Footer with server address copy, nav links, copyright
---

<footer class="bg-surface-deep w-full py-12 border-t border-border-stone mt-auto">
  <div
    class="flex flex-col items-center gap-6 px-margin-desktop text-center max-w-container-max mx-auto"
  >
    <!-- Terminal label -->
    <div class="font-mono text-xs font-medium text-primary mb-4 flex items-center gap-2">
      <span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true"
        >terminal</span
      >
      SYS.TERMINAL.OFFLINE
    </div>

    <!-- Server address copy widget -->
    <div
      class="flex items-center bg-surface-elevated stone-border p-1 w-full max-w-md mx-auto mb-6"
    >
      <div
        id="footer-server-address"
        class="px-4 py-2 font-mono text-xs font-medium text-on-surface border-r border-border-stone select-all flex-1 text-center bg-surface-container-low"
      >
        berongsmpdev.mcsh.io
      </div>
      <button
        id="footer-copy-btn"
        aria-label="Copy server address to clipboard"
        class="px-4 py-2 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-center bg-surface-container-low"
      >
        <span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true"
          >content_copy</span
        >
      </button>
    </div>

    <!-- Footer links -->
    <nav aria-label="Footer navigation">
      <ul class="flex flex-wrap justify-center gap-6 font-mono text-xs font-medium list-none">
        <li>
          <a class="text-primary underline hover:text-primary/80 transition-colors" href="#">
            Terms of Service
          </a>
        </li>
        <li>
          <a
            class="text-text-obsidian hover:text-primary transition-colors"
            href="#"
          >
            Privacy Policy
          </a>
        </li>
        <li>
          <a
            class="text-text-obsidian hover:text-primary transition-colors"
            href="#enroll"
          >
            Contact Support
          </a>
        </li>
      </ul>
    </nav>

    <!-- Copyright -->
    <p class="font-body text-body-sm text-text-obsidian mt-4">
      © 2024 BERONG SMP. A thesis project — not affiliated with Mojang Studios.
    </p>
  </div>
</footer>

<script>
  const btn = document.getElementById('footer-copy-btn');
  const addr = document.getElementById('footer-server-address');
  if (btn && addr) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(addr.textContent?.trim() ?? '');
        const icon = btn.querySelector('span');
        if (icon) {
          icon.textContent = 'check';
          icon.classList.add('text-primary');
          setTimeout(() => {
            icon.textContent = 'content_copy';
            icon.classList.remove('text-primary');
          }, 1800);
        }
      } catch {
        /* no-op in insecure context */
      }
    });
  }
</script>
